local workspace = game:GetService("Workspace")

local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

local hrp = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")

local ex = {"SniperRifle_01", "Noob1", "Terrain", "Camera", "SpawnLocation", "Status", localPlayer.Name}
numOfModels = 0
task.wait(1)


local function models()
	
	--add part at every model in workspace exept in the ex table
	for i, v in pairs(workspace:GetDescendants()) do
		if v:IsA("Model") and not table.find(ex, v.Name) then
			
			

			print("added: " .. v.Name)
			local targetObj = v  
			local tracker = Instance.new("Part")
			tracker.Name = "Part1"
			tracker.Parent = workspace
			tracker.Size = Vector3.new(1, 1, 5)
			tracker.CanCollide = true
			tracker.Anchored = true



			local cframe, _ = targetObj:GetBoundingBox()
			tracker.Position = cframe.Position + Vector3.new(0, 2, 0)

			-- Orient the tracker so its front faces the local player's HumanoidRootPart.
			tracker.CFrame = CFrame.lookAt(tracker.Position, hrp.Position)

			numOfModels = numOfModels + 1



		end
	end
end


print(numOfModels)

humanoid.Running:Connect(function(speed)
	if speed > 0 then
		for i, v in pairs(workspace:GetDescendants()) do
			if v.Name == "Part1" then
				v:Destroy()
			end
		end
		models()
	end
end)
