--[[
    TakeBlocksScript.lua
    This LocalScript continuously checks the blocks in:
    workspace.Plots.[user].Blocks

    Auto Merge:
        1. Groups blocks by the Text property of the TextLabel inside each block’s "Back" SurfaceGui.
        2. Only attempts to pick up and merge from groups that have duplicates.
           This prevents picking up a block without a match and holding it forever.
        3. If the user toggles OFF auto merging mid-process, it stops immediately.

    Auto Tap:
        1. Rapidly fires (taps) blocks while active, with minimal impact on performance.
        2. Properly stops when toggled OFF and releases all related tasks.
        3. Uses small waits but remains fast to reduce lag.

    This script creates a draggable GUI with two toggle buttons:
        "Auto Merge": ON/OFF
        "Auto Tap": ON/OFF

    Place this LocalScript (e.g. in StarterPlayerScripts) so it runs on the client side.
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
if not player then
	warn("LocalPlayer not found!")
	return
end

local user = player.Name
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")
hrp.CanCollide = false

-- References to remote events/functions (replace with your actual objects if named differently)
local TakeBlockEvent = ReplicatedStorage:WaitForChild("Functions"):WaitForChild("TakeBlock")
local TapEvent = ReplicatedStorage:WaitForChild("Functions"):WaitForChild("Tap")
local blocksFolder = workspace:WaitForChild("Plots"):WaitForChild(user):WaitForChild("Blocks")

-- GUI Setup
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "AutoTakeBlockGui"
ScreenGui.Parent = player:WaitForChild("PlayerGui")

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 200, 0, 80) -- Enough height for two buttons
mainFrame.Position = UDim2.new(0.5, -100, 0.5, -40) -- Centered on the screen
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
mainFrame.Active = true
mainFrame.Draggable = true
mainFrame.Parent = ScreenGui

local autoMergeButton = Instance.new("TextButton")
autoMergeButton.Size = UDim2.new(0, 150, 0, 30)
autoMergeButton.Position = UDim2.new(0, 25, 0, 10)
autoMergeButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
autoMergeButton.Text = "Auto Merge: OFF"
autoMergeButton.TextColor3 = Color3.new(1, 1, 1)
autoMergeButton.Parent = mainFrame

local autoTapButton = Instance.new("TextButton")
autoTapButton.Size = UDim2.new(0, 150, 0, 30)
autoTapButton.Position = UDim2.new(0, 25, 0, 45)
autoTapButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
autoTapButton.Text = "Auto Tap: OFF"
autoTapButton.TextColor3 = Color3.new(1, 1, 1)
autoTapButton.Parent = mainFrame

-- State variables
local autoMergeActive = false
local autoTapActive = false

-- Build groups for merging (maps textValue -> {block1, block2, ...})
local function buildGroups()
	local groups = {}
	for _, block in ipairs(blocksFolder:GetChildren()) do
		if block:IsA("BasePart") then
			local back = block:FindFirstChild("Back")
			if back then
				local textLabel = back:FindFirstChildWhichIsA("TextLabel")
				if textLabel then
					local textValue = textLabel.Text
					groups[textValue] = groups[textValue] or {}
					table.insert(groups[textValue], block)
				end
			end
		end
	end
	return groups
end

-- Reliable function to pick up and fire TakeBlock for a block with minimal delay
local function mergePickup(block)
	if not block or not block.Parent then return end
	local maxAttempts = 5
	for attempt = 1, maxAttempts do
		if not autoMergeActive then return end -- Stop if toggled off mid-process
		if not block or not block.Parent then return end

		hrp.CFrame = block.CFrame * CFrame.new(0, 2, -3)
		RunService.Heartbeat:Wait()
		hrp.CFrame = CFrame.lookAt(hrp.Position, block.Position)
		RunService.Heartbeat:Wait()

		local success, err = pcall(function()
			TakeBlockEvent:FireServer(block)
		end)
		if not success then
			warn("Failed to TakeBlock for: " .. block.Name .. " - " .. tostring(err))
		end
		task.wait(0.05)
	end
end

-- Continuously merges blocks from groups of duplicates only
local function processBlocks()
	while autoMergeActive do
		local groups = buildGroups()
		for textValue, blockList in pairs(groups) do
			if not autoMergeActive then break end
			if #blockList >= 2 then
				-- If there are duplicates, pick them up one by one
				for _, block in ipairs(blockList) do
					if not autoMergeActive then break end
					-- Double-check if the block is still valid and in a group with duplicates
					local stillInGroups = buildGroups() -- Re-check quickly in case blocks changed
					local updatedList = stillInGroups[textValue] or {}
					-- If we still have at least 2 in that group, proceed
					if #updatedList >= 2 and block.Parent == blocksFolder then
						mergePickup(block)
					end
					task.wait(0.01)
				end
			end
		end
		task.wait(0.05) -- brief wait to lessen load
	end
end

-- Continuously taps blocks in parallel but maintain a loop that stops on toggle
local function processFastTapLoop()
	while autoTapActive do
		local allBlocks = blocksFolder:GetChildren()
		if not autoTapActive then break end

		-- Rapidly fire Tap on each block
		for _, block in ipairs(allBlocks) do
			if not autoTapActive then break end
			if block:IsA("BasePart") and block.Parent == blocksFolder then
				task.spawn(function()
					local success, err = pcall(function()
						TapEvent:FireServer(block)
					end)
					if not success then
						warn("TapEvent fail for block: " .. block.Name .. " - " .. tostring(err))
					end
				end)
			end
		end

		-- Short wait to reduce overhead while remaining fast
		task.wait(0.01)
	end
end

autoMergeButton.MouseButton1Click:Connect(function()
	autoMergeActive = not autoMergeActive
	if autoMergeActive then
		autoMergeButton.Text = "Auto Merge: ON"
		task.spawn(processBlocks)
	else
		autoMergeButton.Text = "Auto Merge: OFF"
	end
end)

autoTapButton.MouseButton1Click:Connect(function()
	autoTapActive = not autoTapActive
	if autoTapActive then
		autoTapButton.Text = "Auto Tap: ON"
		task.spawn(processFastTapLoop)
	else
		autoTapButton.Text = "Auto Tap: OFF"
	end
end)

print("Optimized TakeBlocksScript with centered GUI, toggles, no perma-holding, and minimal-lag concurrency.")
