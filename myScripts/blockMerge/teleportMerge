--[[
    TakeBlocksScript.lua
    This LocalScript goes through each block in:
    workspace.Plots.[user].Blocks

    It first groups blocks based on the Text property of the TextLabel inside each block’s "Back" SurfaceGui.
    If a block’s group has only one block (i.e. no duplicate/matching value), it is skipped.
    For groups with duplicates, the player is teleported near each block, with the HumanoidRootPart
    rotated to face the block.
    
    Place this LocalScript in a location where it can run (e.g. StarterPlayerScripts).
--]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
if not player then
	warn("LocalPlayer not found!")
	return
end
local user = player.Name

local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")
hrp.CanCollide = false

-- Path to the Blocks folder
local blocksFolder = workspace:WaitForChild("Plots"):WaitForChild(user):WaitForChild("Blocks")
local TakeBlockEvent = ReplicatedStorage:WaitForChild("Functions"):WaitForChild("TakeBlock")

-- Group blocks by the Text property of the TextLabel in the "Back" SurfaceGui.
local groups = {}
for _, block in ipairs(blocksFolder:GetChildren()) do
	if block:IsA("BasePart") then
		local back = block:FindFirstChild("Back")
		if back then
			local textLabel = back:FindFirstChildWhichIsA("TextLabel")
			if textLabel then
				local textValue = textLabel.Text
				groups[textValue] = groups[textValue] or {}
				table.insert(groups[textValue], block)
			else
				warn("Block " .. block.Name .. " is missing a TextLabel in 'Back'")
			end
		else
			warn("Block " .. block.Name .. " is missing the 'Back' SurfaceGui")
		end
	end
end

-- Process only groups with matching values (i.e. at least 2 blocks)
for textValue, blockList in pairs(groups) do
	if #blockList < 2 then
		print("Skipping group with Text value: " .. textValue .. " because it has no duplicate.")
	else
		print("Processing group with Text value: " .. textValue .. " (" .. #blockList .. " block(s))")
		for _, block in ipairs(blockList) do
			-- Teleport the player close to the block (offset 3 studs behind the block)
			hrp.CFrame = block.CFrame * CFrame.new(0, 0, -3)
			task.wait(0.2)
			-- Orient the player to face the block's position (so that they collide)
			hrp.CFrame = CFrame.lookAt(hrp.Position, block.Position)
			task.wait(0.2)

			-- Fire the TakeBlock event for the current block
			TakeBlockEvent:FireServer(block)
			task.wait(0.1)  -- Wait before moving to the next block
		end
	end
end

print("Processed all matching blocks.")
