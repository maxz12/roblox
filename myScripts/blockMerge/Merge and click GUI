--[[
    TakeBlocksScript.lua
    This LocalScript goes through each block in:
    workspace.Plots.[user].Blocks

    It groups blocks based on the Text property of the TextLabel inside each block’s "Back" SurfaceGui.
    If a block’s group has only one block (i.e. no duplicate/matching value), it is skipped.
    For groups with duplicates, the player is teleported near each block, oriented to face the block,
    and the TakeBlock event is fired reliably.
    
    A draggable GUI with two toggle buttons is added. When "Auto Merge" is toggled ON, it will continuously loop 
    through the block groups with duplicates and process them to reliably pick up the blocks. 
    When "Auto Tap" is toggled ON, it will continuously scan the blocks and fire the Tap event 
    on the one with the highest value (the Text number in its TextLabel). Each time a block is clicked or when a new 
    block with a higher value is detected and switched to, the script prints the block's name and its value in two separate prints.
    
    Place this LocalScript in a location where it can run (e.g. StarterPlayerScripts).
--]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
if not player then
	warn("LocalPlayer not found!")
	return
end
local user = player.Name

local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")
hrp.CanCollide = false

-- Create the AutoTakeBlock GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "AutoTakeBlockGui"
ScreenGui.Parent = player:WaitForChild("PlayerGui")

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 200, 0, 80)  -- increased height to accommodate two buttons
mainFrame.Position = UDim2.new(0.5, -100, 0.5, -40)  -- starts centered on the screen
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
mainFrame.Active = true
mainFrame.Draggable = true
mainFrame.Parent = ScreenGui

local autoMergeButton = Instance.new("TextButton")
autoMergeButton.Size = UDim2.new(0, 150, 0, 30)
autoMergeButton.Position = UDim2.new(0, 25, 0, 10)
autoMergeButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
autoMergeButton.Text = "Auto Merge: OFF"
autoMergeButton.TextColor3 = Color3.new(1, 1, 1)
autoMergeButton.Parent = mainFrame

local autoTapButton = Instance.new("TextButton")
autoTapButton.Size = UDim2.new(0, 150, 0, 30)
autoTapButton.Position = UDim2.new(0, 25, 0, 45)
autoTapButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
autoTapButton.Text = "Auto Tap: OFF"
autoTapButton.TextColor3 = Color3.new(1, 1, 1)
autoTapButton.Parent = mainFrame

local autoMergeActive = false
local autoTapActive = false

-- Paths for Blocks and replicated functions
local blocksFolder = workspace:WaitForChild("Plots"):WaitForChild(user):WaitForChild("Blocks")
local TakeBlockEvent = ReplicatedStorage:WaitForChild("Functions"):WaitForChild("TakeBlock")
local TapEvent = ReplicatedStorage:WaitForChild("Functions"):WaitForChild("Tap")

-- Function to build block groups based on the Text property in the "Back" SurfaceGui.
local function buildGroups()
	local groups = {}
	for _, block in ipairs(blocksFolder:GetChildren()) do
		if block:IsA("BasePart") then
			local back = block:FindFirstChild("Back")
			if back then
				local textLabel = back:FindFirstChildWhichIsA("TextLabel")
				if textLabel then
					local textValue = textLabel.Text
					groups[textValue] = groups[textValue] or {}
					table.insert(groups[textValue], block)
				else
					warn("Block " .. block.Name .. " is missing a TextLabel in 'Back'")
				end
			else
				warn("Block " .. block.Name .. " is missing the 'Back' SurfaceGui")
			end
		end
	end
	return groups
end

-- Function to process individual block pickup reliably.
local function processBlock(block)
	local maxAttempts = 5
	local attempt = 0
	repeat
		if not block or not block.Parent then
			break
		end
		-- Teleport the player near the block (3 studs behind the block)
		hrp.CFrame = block.CFrame * CFrame.new(0, 2, -3)
		RunService.Heartbeat:Wait()
		-- Orient the player to face the block’s position
		hrp.CFrame = CFrame.lookAt(hrp.Position, block.Position)
		RunService.Heartbeat:Wait()
		-- Fire the TakeBlock event
		local success = pcall(function()
			TakeBlockEvent:FireServer(block)
		end)
		if not success then
			warn("Failed to fire TakeBlock event for block " .. block.Name)
		end
		attempt = attempt + 1
		task.wait(0.05)
	until not block or not block.Parent or attempt >= maxAttempts
end

local function processBlocks()
	while autoMergeActive do
		local groups = buildGroups()
		for textValue, blockList in pairs(groups) do
			-- Process only groups with duplicates
			if #blockList >= 2 then
				for _, block in ipairs(blockList) do
					if not autoMergeActive then return end
					if block and block.Parent then
						processBlock(block)
					end
					task.wait(0.01)
				end
			end
		end
		task.wait(0.01)
	end
end

-- New function to continuously scan and tap the block with the highest value.
local function processHighestTapLoop()
	local currentTappedBlock = nil
	while autoTapActive do
		local highestBlock = nil
		local highestValue = -math.huge
		for _, block in ipairs(blocksFolder:GetChildren()) do
			if block:IsA("BasePart") then
				local back = block:FindFirstChild("Back")
				if back then
					local textLabel = back:FindFirstChildWhichIsA("TextLabel")
					if textLabel then
						local value = tonumber(textLabel.Text)
						if value and value > highestValue then
							highestValue = value
							highestBlock = block
						end
					end
				end
			end
		end
		
		-- If a highest block is found, fire the tap event and print its details
		if highestBlock then
			-- Check if we have switched blocks or tapping the same one again.
			if currentTappedBlock ~= highestBlock then
				currentTappedBlock = highestBlock
			end
			
			local success, err = pcall(function()
				TapEvent:FireServer(highestBlock)
			end)
			if not success then
				warn("Failed to fire Tap event for block " .. highestBlock.Name .. ": " .. tostring(err))
			else
				-- Print block's name and value in two separate prints
				print("Tapped block: " .. highestBlock.Name)
				print("Block value: " .. tostring(highestValue))
			end
		end
		task.wait(0.05)
	end
end

autoMergeButton.MouseButton1Click:Connect(function()
	autoMergeActive = not autoMergeActive
	if autoMergeActive then
		autoMergeButton.Text = "Auto Merge: ON"
		task.spawn(processBlocks)
	else
		autoMergeButton.Text = "Auto Merge: OFF"
	end
end)

autoTapButton.MouseButton1Click:Connect(function()
	autoTapActive = not autoTapActive
	if autoTapActive then
		autoTapButton.Text = "Auto Tap: ON"
		task.spawn(processHighestTapLoop)
	else
		autoTapButton.Text = "Auto Tap: OFF"
	end
end)

print("Initialized improved TakeBlocksScript with centered GUI, auto merge, and highest-value auto tap functionality with printing.")
