-- Setup death handler for current and future characters
local function setupCharacter(char)
    if not char then return end
    local hum = char:WaitForChild("Humanoid")
    
    -- Handle character death
    hum.Died:Connect(function()
        isAlive = false
        triggerActive = false
        if targetHighlight.Parent then
            targetHighlight.Parent = nil
        end
        if currentTween then
            currentTween:Cancel()
        end
        -- Disable all GUI buttons
        toggleButton.Text = "ACTIVATE TRIGGER"
        statusIndicator.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        hitToggle.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        moveToggle.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        fallToggle.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        hitToggle.Active = false
        moveToggle.Active = false
        fallToggle.Active = false
        toggleButton.Active = false
    end)
    
    isAlive = true
    -- Re-enable GUI when alive
    if toggleButton then
        toggleButton.Active = true
        hitToggle.Active = true
        moveToggle.Active = true
        fallToggle.Active = true
    end
    
    -- Set initial safe position
    task.wait(1)
    if char:FindFirstChild("HumanoidRootPart") then
        lastSafePosition = char.HumanoidRootPart.CFrame
    end
end

setupCharacter(character)
LocalPlayer.CharacterAdded:Connect(setupCharacter)

