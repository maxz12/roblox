-- workspace.littletimmy2017a["Colt .45"].ColtLocal

local tool = script.Parent
local handle = tool:WaitForChild("Handle")

local sounds = {
	["Fire"] = handle:WaitForChild("Fire"),
	["Reload"] = handle:WaitForChild("Reload"),
	["Equip"] = handle:WaitForChild("Equip"),
	["Prep"] = handle:WaitForChild("Prep"),
	["Empty"] = handle:WaitForChild("Empty")
}

local animationIds = {
	["Hold"] = "rbxassetid://03151590218",
	["Reload"] = "rbxassetid://02536241233",
	["Fire"] = "rbxassetid://02542178379",
	["FanFire"] = "rbxassetid://2870647263",
	["Equip"] = "rbxassetid://03151619079",
	["Zoom"] = "rbxassetid://02536242563",
	["Idle"] = "rbxassetid://03118841150"
}

for _, sound in next, sounds do
	sound.Parent = handle
end

local gunLocalModule = require(game.ReplicatedStorage:WaitForChild("GunScripts"):WaitForChild("GunLocalModule"))()
local animations = gunLocalModule:LoadAnimations(animationIds)
local gunStats = require(game.ReplicatedStorage.GunScripts.GunStats)[tool.Name]

function gunLocalModule.PlayAnimation(toolInstance, animationName, condition)
	spawn(function()
		if toolInstance.Equipped then
			if animationName == "Equip" then
				animations.Equip:Play()
				animations.Idle:Play()
				return
			elseif animationName == "Reload" then
				if condition then
					animations.Reload:Play(0.1, 1, gunStats.ReloadAnimationSpeed)
				else
					animations.Reload:Stop()
				end
			elseif animationName == "Zoom" then
				if condition then
					animations.Zoom:Play()
				else
					animations.Zoom:Stop()
				end
			elseif animationName == "Hold" then
				animations.Hold:Play()
				return
			elseif animationName == "Fire" then
				sounds.Fire.Pitch = math.random(10, 12) * 0.1
				sounds.Fire:Play()
				animations.Fire:Play()
				animations.Idle:Stop()
				wait(0.4)
				if toolInstance.Equipped then
					sounds.Prep:Play()
					animations.Idle:Play()
				end
			elseif animationName == "FanFire" then
				sounds.Fire.Pitch = math.random(10, 12) * 0.1
				sounds.Fire:Play()
				animations.FanFire:Play()
				animations.Idle:Stop()
				wait(0.2)
				if toolInstance.Equipped then
					sounds.Prep:Play()
					animations.Idle:Play(0.05)
				end
			else
				local _ = animationName == "Unequip"
				return
			end
		else
			return
		end
	end)
end

gunLocalModule:CreateGun({
	["Tool"] = tool,
	["GunStats"] = gunStats,
	["Sounds"] = sounds
})
