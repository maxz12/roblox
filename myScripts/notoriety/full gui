-- Police teleport feature
local policeTeleportConnection = nil
local PoliceTeleport = PoliceSection:Toggle({
    Name = "Teleport Police In Front",
    Value = false,
    Callback = function(enabled)
        if enabled then
            -- Create a new connection when enabled
            policeTeleportConnection = RunService.Heartbeat:Connect(function()
                -- Get player's position and forward direction
                local position = hrp.Position
                local lookDirection = hrp.CFrame.LookVector
                
                -- Position to place officers (5 studs in front)
                local targetPosition = position + (lookDirection * 5)
                
                -- Teleport all police officers to this position
                for _, officer in pairs(workspace.Police:GetChildren()) do
                    local officerHRP = officer:FindFirstChild("HumanoidRootPart")
                    if officerHRP then
                        -- Face the player
                        local lookAt = CFrame.lookAt(targetPosition, position)
                        officerHRP.CFrame = lookAt
                    end
                end
            end)
            table.insert(connections, policeTeleportConnection)
        else
            -- Disconnect when disabled
            if policeTeleportConnection then
                policeTeleportConnection:Disconnect()
                policeTeleportConnection = nil
            end
        end
    end
})
PoliceTeleport:ToolTip("Teleports police officers 5 studs in front of you, facing you")
