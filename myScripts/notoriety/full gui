-- Police highlight feature (now with red color)
local policeHighlights = {}
local policeHighlightConnection = nil
local policeChildRemovedConnection = nil
local PoliceHighlight = PoliceSection:Toggle({
    Name = "Highlight Police (Red)",
    Value = false,
    Callback = function(enabled)
        -- Function to apply highlight
        local function addHighlight(officer)
            if not enabled then 
                if policeHighlights[officer] then
                    policeHighlights[officer]:Destroy()
                    policeHighlights[officer] = nil
                end
                return 
            end
            
            if not policeHighlights[officer] then
                local highlight = Instance.new("Highlight")
                highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Red
                highlight.OutlineColor = Color3.fromRGB(180, 0, 0) -- Darker red
                highlight.FillTransparency = 0.7
                highlight.Parent = officer
                policeHighlights[officer] = highlight
                
                -- Remove on death
                local humanoid = officer:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid.Died:Connect(function()
                        if policeHighlights[officer] then
                            policeHighlights[officer]:Destroy()
                            policeHighlights[officer] = nil
                        end
                    end)
                end
            end
        end
        
        -- Apply to existing officers
        for _, officer in pairs(workspace.Police:GetChildren()) do
            if enabled then
                addHighlight(officer)
            else
                if policeHighlights[officer] then
                    policeHighlights[officer]:Destroy()
                    policeHighlights[officer] = nil
                end
            end
        end
        
        -- Connect to future officers
        if enabled then
            policeHighlightConnection = workspace.Police.ChildAdded:Connect(addHighlight)
            table.insert(connections, policeHighlightConnection)
            
            policeChildRemovedConnection = workspace.Police.ChildRemoved:Connect(function(officer)
                if policeHighlights[officer] then
                    policeHighlights[officer]:Destroy()
                    policeHighlights[officer] = nil
                end
            end)
            table.insert(connections, policeChildRemovedConnection)
        else
            if policeHighlightConnection then
                policeHighlightConnection:Disconnect()
                policeHighlightConnection = nil
            end
            
            if policeChildRemovedConnection then
                policeChildRemovedConnection:Disconnect()
                policeChildRemovedConnection = nil
            end
            
            -- Remove all highlights
            for officer, highlight in pairs(policeHighlights) do
                highlight:Destroy()
            end
            policeHighlights = {}
        end
    end
})
