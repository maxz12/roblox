local GunModsSection = MainTab:Section({Name = "Gun Mods", Side = "Right"})

-- Track settings
local gunSettings = {
    fastReload = false,
    fastFireRate = false,
    noRecoil = false,
    infiniteAmmo = false
}

-- Function to modify a gun's properties
local function modifyGunModule(gunData)
    if not gunData then return false end
    
    local success, module = pcall(function()
        return require(gunData)
    end)
    
    if not success or not module then
        return false
    end
    
    -- Apply mods based on settings
    if gunSettings.fastReload then
        module.ReloadTime = 0.05
        module.LongerReloadTime = 0.05
    end
    
    if gunSettings.fastFireRate then
        module.FireDelay = 0.02
    end
    
    if gunSettings.noRecoil then
        module.RecoilDirectionPattern = {Vector2.new(0, 0), Vector2.new(0, 0), Vector2.new(0, 0), Vector2.new(0, 0)}
        module.RecoilCameraDirectionPattern = {Vector2.new(0, 0), Vector2.new(0, 0)}
        module.ShakeMagnitude = 0
        module.Knockback = 0
        module.PushBack = 0
    end
    
    return true
end

-- Main function to check for and modify guns
local function setupGunModifiers()
    local plr = game.Players.LocalPlayer
    local backpack = plr.Backpack
    local criminalFolder = workspace:FindFirstChild("Criminals")
    local plrFolder = criminalFolder and criminalFolder:FindFirstChild(plr.Name)
    
    -- Watch for when the player equips a weapon
    local characterConnection
    if plr.Character then
        characterConnection = plr.Character.ChildAdded:Connect(function(item)
            if item:IsA("Tool") then
                task.wait(0.1) -- Brief wait for gun to fully load
                
                -- Find the gun data
                if plrFolder and plrFolder:FindFirstChild(item.Name) then
                    local gunFolder = plrFolder:FindFirstChild(item.Name)
                    local gunData = gunFolder and gunFolder:FindFirstChild("Data")
                    
                    if gunData then
                        if modifyGunModule(gunData) then
                            Bracket:Notification({
                                Title = "Gun Modified",
                                Description = "Applied mods to " .. item.Name,
                                Duration = 1
                            })
                        end
                    end
                end
            end
        end)
        table.insert(connections, characterConnection)
    end
    
    -- Watch for when character is added (respawn)
    local charAddedConnection = plr.CharacterAdded:Connect(function(char)
        if characterConnection then
            characterConnection:Disconnect()
        end
        
        characterConnection = char.ChildAdded:Connect(function(item)
            if item:IsA("Tool") then
                task.wait(0.1)
                
                -- Find the gun data
                if plrFolder and plrFolder:FindFirstChild(item.Name) then
                    local gunFolder = plrFolder:FindFirstChild(item.Name)
                    local gunData = gunFolder and gunFolder:FindFirstChild("Data")
                    
                    if gunData then
                        if modifyGunModule(gunData) then
                            Bracket:Notification({
                                Title = "Gun Modified",
                                Description = "Applied mods to " .. item.Name,
                                Duration = 1
                            })
                        end
                    end
                end
            end
        end)
        table.insert(connections, characterConnection)
    end)
    table.insert(connections, charAddedConnection)
    
    -- Watch for changes in the workspace.Criminals folder
    local gunsModified = {}
    
    local criminalsChildAddedConn = workspace.ChildAdded:Connect(function(child)
        if child.Name == "Criminals" then
            local plrFolderWatcher
            
            plrFolderWatcher = child.ChildAdded:Connect(function(playerFolder)
                if playerFolder.Name == plr.Name then
                    -- Watch for gun folders being added
                    local gunFolderAddedConn = playerFolder.ChildAdded:Connect(function(gunFolder)
                        if gunFolder:IsA("Folder") and not gunFolder.Name:match("Ammo") and not gunFolder.Name:match("Speed") then
                            task.wait(0.1)
                            local gunData = gunFolder:FindFirstChild("Data")
                            
                            if gunData and not gunsModified[gunData] then
                                if modifyGunModule(gunData) then
                                    gunsModified[gunData] = true
                                    Bracket:Notification({
                                        Title = "Gun Modified",
                                        Description = "Applied mods to " .. gunFolder.Name,
                                        Duration = 1
                                    })
                                end
                            end
                        end
                    end)
                    table.insert(connections, gunFolderAddedConn)
                    
                    -- Check existing gun folders
                    for _, gunFolder in pairs(playerFolder:GetChildren()) do
                        if gunFolder:IsA("Folder") and not gunFolder.Name:match("Ammo") and not gunFolder.Name:match("Speed") then
                            local gunData = gunFolder:FindFirstChild("Data")
                            
                            if gunData and not gunsModified[gunData] then
                                if modifyGunModule(gunData) then
                                    gunsModified[gunData] = true
                                    Bracket:Notification({
                                        Title = "Gun Modified", 
                                        Description = "Applied mods to " .. gunFolder.Name,
                                        Duration = 1
                                    })
                                end
                            end
                        end
                    end
                end
            end)
            table.insert(connections, plrFolderWatcher)
            
            -- Check if player folder already exists
            if child:FindFirstChild(plr.Name) then
                local playerFolder = child:FindFirstChild(plr.Name)
                
                -- Check existing gun folders
                for _, gunFolder in pairs(playerFolder:GetChildren()) do
                    if gunFolder:IsA("Folder") and not gunFolder.Name:match("Ammo") and not gunFolder.Name:match("Speed") then
                        local gunData = gunFolder:FindFirstChild("Data")
                        
                        if gunData and not gunsModified[gunData] then
                            if modifyGunModule(gunData) then
                                gunsModified[gunData] = true
                                Bracket:Notification({
                                    Title = "Gun Modified",
                                    Description = "Applied mods to " .. gunFolder.Name,
                                    Duration = 1
                                })
                            end
                        end
                    end
                end
            end
        end
    end)
    table.insert(connections, criminalsChildAddedConn)
    
    -- Check if Criminals folder already exists
    if workspace:FindFirstChild("Criminals") then
        if workspace.Criminals:FindFirstChild(plr.Name) then
            local playerFolder = workspace.Criminals:FindFirstChild(plr.Name)
            
            -- Check existing gun folders
            for _, gunFolder in pairs(playerFolder:GetChildren()) do
                if gunFolder:IsA("Folder") and not gunFolder.Name:match("Ammo") and not gunFolder.Name:match("Speed") then
                    local gunData = gunFolder:FindFirstChild("Data")
                    
                    if gunData and not gunsModified[gunData] then
                        if modifyGunModule(gunData) then
                            gunsModified[gunData] = true
                            Bracket:Notification({
                                Title = "Gun Modified",
                                Description = "Applied mods to " .. gunFolder.Name,
                                Duration = 1
                            })
                        end
                    end
                end
            end
        end
    end
end

