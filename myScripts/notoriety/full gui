-- MONEY BAGS SECTION
local BagsSection = MainTab:Section({Name = "Money Bags", Side = "Right"})

-- Global variables to track state
local autoCollectEnabled = false
local monitoringLoop = nil

local AutoCollectBags = BagsSection:Toggle({
    Name = "Auto-Collect Money Bags",
    Value = false,
    Callback = function(enabled)
        autoCollectEnabled = enabled
        
        if enabled then
            -- Create a single monitoring loop that runs continuously
            if monitoringLoop then
                task.cancel(monitoringLoop)
            end
            
            monitoringLoop = task.spawn(function()
                while autoCollectEnabled and task.wait(0.2) do
                    -- Check if bags folder exists
                    local bagsFolder = workspace:FindFirstChild("Bags")
                    if not bagsFolder then continue end
                    
                    -- Check drop area exists
                    local dropArea = workspace:FindFirstChild("BagSecuredArea")
                    if not dropArea then continue end
                    
                    local floorPart = dropArea:FindFirstChild("FloorPart")
                    if not floorPart then continue end
                    
                    -- Process all bags
                    for _, bag in pairs(bagsFolder:GetChildren()) do
                        if not bag or not bag:IsA("Model") or bag.Name ~= "Bag" then continue end
                        
                        local moneyBag = bag:FindFirstChild("MoneyBag")
                        if not moneyBag then continue end
                        
                        -- If bag doesn't have a weld, it's dropped - teleport it
                        if not moneyBag:FindFirstChild("BagWeld") then
                            -- Set primary part if needed
                            if not bag.PrimaryPart then
                                bag.PrimaryPart = moneyBag
                            end
                            
                            -- Only teleport if it's not already at drop area
                            local bagPos = bag:GetPrimaryPartCFrame().Position
                            local dropPos = floorPart.Position
                            
                            -- If bag is more than 10 studs away from drop area
                            if (bagPos - dropPos).Magnitude > 10 then
                                -- Teleport the bag
                                bag:SetPrimaryPartCFrame(CFrame.new(floorPart.Position + Vector3.new(0, 1, 0)))
                                
                                Bracket:Notification({
                                    Title = "Money Bag Collected",
                                    Description = "Bag teleported to drop-off",
                                    Duration = 1
                                })
                            end
                        end
                    end
                end
            end)
            
            -- Add to connections for cleanup
            table.insert(connections, function()
                if monitoringLoop then
                    task.cancel(monitoringLoop)
                    monitoringLoop = nil
                end
            end)
            
            Bracket:Notification({
                Title = "Auto-Collect Enabled",
                Description = "Now monitoring for dropped money bags",
                Duration = 2
            })
        else
            -- Clean up monitoring loop
            if monitoringLoop then
                task.cancel(monitoringLoop)
                monitoringLoop = nil
            end
            
            Bracket:Notification({
                Title = "Auto-Collect Disabled",
                Description = "No longer collecting money bags",
                Duration = 2
            })
        end
    end
})

