-- Manual implementation of UI toggle with fixed RightShift keybind
local guiVisible = true
local toggleKey = Enum.KeyCode.RightShift -- Fixed RightShift key

-- Listen for key presses globally
local keyConnection = UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if gameProcessed then return end -- Ignore if game processed the input
    
    if input.KeyCode == toggleKey then
        guiVisible = not guiVisible
        Window:Toggle(guiVisible)
        
        Bracket:Notification({
            Title = guiVisible and "GUI Visible" or "GUI Hidden",
            Description = "Press RightShift to " .. (guiVisible and "hide" or "show"),
            Duration = 1.5
        })
    end
end)
table.insert(connections, keyConnection)

-- Destroy UI button
local DestroyButton = SettingsSection:Button({
    Name = "Destroy GUI",
    Callback = function()
        -- Clean up all connections
        for _, connection in pairs(connections) do
            if connection and typeof(connection) == "RBXScriptConnection" and connection.Connected then
                connection:Disconnect()
            end
        end
        connections = {}
        
        -- Clean up highlight objects
        for officer, highlight in pairs(policeHighlights) do
            if highlight then
                highlight:Destroy()
            end
        end
        policeHighlights = {}
        
        for citizen, highlight in pairs(citizenHighlights) do
            if highlight then
                highlight:Destroy()
            end
        end
        citizenHighlights = {}
        
        -- Notification before destroying
        Bracket:Notification({
            Title = "GUI Destroyed",
            Description = "Thanks for using Prison Life GUI!",
            Duration = 2
        })
        
        -- Destroy the UI
        Window:Remove()
    end
})
DestroyButton:ToolTip("Completely removes the GUI and cleans up all connections")
