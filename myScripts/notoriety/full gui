-- Infinite Ammo Toggle - Super Fast Implementation
local ammoLoop = nil
local InfiniteAmmo = GunModsSection:Toggle({
    Name = "Infinite Ammo",
    Value = false,
    Callback = function(enabled)
        gunSettings.infiniteAmmo = enabled
        
        if enabled then
            if ammoLoop then
                task.cancel(ammoLoop)
            end
            
            ammoLoop = task.spawn(function()
                local plrName = game.Players.LocalPlayer.Name
                
                -- Direct references to avoid lookups in the loop
                local criminalFolder = workspace:FindFirstChild("Criminals")
                if not criminalFolder then return end
                
                local playerFolder = criminalFolder:FindFirstChild(plrName)
                if not playerFolder then return end
                
                local primaryAmmo = playerFolder:FindFirstChild("PrimaryAmmo")
                local primaryAmmoMax = playerFolder:FindFirstChild("PrimaryAmmoMax")
                
                if not primaryAmmo or not primaryAmmoMax then return end
                
                -- Super fast loop using Heartbeat
                while true do
                    primaryAmmo.Value = 999
                    primaryAmmoMax.Value = 999
                    RunService.Heartbeat:Wait()
                end
            end)
            
            table.insert(connections, function()
                if ammoLoop then
                    task.cancel(ammoLoop)
                    ammoLoop = nil
                end
            end)
            
            Bracket:Notification({
                Title = "Infinite Ammo",
                Description = "Enabled infinite ammo",
                Duration = 2
            })
        else
            if ammoLoop then
                task.cancel(ammoLoop)
                ammoLoop = nil
            end
            
            Bracket:Notification({
                Title = "Infinite Ammo",
                Description = "Disabled infinite ammo",
                Duration = 2
            })
        end
    end
})
InfiniteAmmo:ToolTip("Never run out of ammo")
InfiniteAmmo:Keybind({
    Key = "NONE",
    Mouse = false,
    Blacklist = {"W","A","S","D","Slash","Tab","Backspace","Escape","Space","Delete","Unknown","Backquote"}
})

