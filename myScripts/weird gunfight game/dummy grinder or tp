-- Generic slider implementation
local function setupSlider(slider, fill, maxVal, configKey, label, prefix, suffix)
    local isSliding = false
    
    -- Update function
    local function updateValue(relX)
        local newVal = math.max(0.1, math.min(maxVal, relX * maxVal))
        config[configKey] = newVal
        fill.Size = UDim2.new(newVal / maxVal, 0, 1, 0)
        label.Text = prefix .. string.format("%.1f", newVal) .. suffix
    end
    
    -- Handle mouse down
    slider.MouseButton1Down:Connect(function(x)
        isSliding = true
        local relX = math.clamp(x / slider.AbsoluteSize.X, 0, 1)
        updateValue(relX)
    end)
    
    -- Handle mouse move
    UserInputService.InputChanged:Connect(function(input)
        if isSliding and input.UserInputType == Enum.UserInputType.MouseMovement then
            local mousePos = UserInputService:GetMouseLocation()
            local sliderPos = slider.AbsolutePosition
            local sliderSize = slider.AbsoluteSize
            
            if mousePos.X >= sliderPos.X and mousePos.X <= sliderPos.X + sliderSize.X then
                local relX = math.clamp((mousePos.X - sliderPos.X) / sliderSize.X, 0, 1)
                updateValue(relX)
            end
        end
    end)
    
    -- Handle mouse up
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isSliding = false
        end
    end)
end

