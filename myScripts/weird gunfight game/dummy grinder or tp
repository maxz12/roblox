local targets = game.Workspace.Targets.MatchTargets:GetChildren()
local validTargets = {}
local char = game.Players.localPlayer.Character
local hrp = char:WaitForChild("HumanoidRootPart")

local gui = Instance.new("ScreenGui")
gui.Parent = game.CoreGui

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 150, 0, 50)
button.Position = UDim2.new(0.5, -75, 0.5, -25)
button.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
button.Text = "OFF"
button.Parent = gui
button.Draggable = true

-- Initialize enabled state ONCE
local enabled = false

-- Function to update valid targets
local function updateValidTargets()
    table.clear(validTargets) -- Clear previous targets
    for i, v in pairs(targets) do
        if v:FindFirstChild("Head") then
            table.insert(validTargets, v)
			print(v.Name)
        end
    end
end

-- Function to move heads
local function moveHeads()
    -- Only run if enabled
    if not enabled then return end
    
    -- Update target list
    updateValidTargets()
    
    -- Initial bring to player
    for i, v in pairs(validTargets) do
        v.Head.Position = hrp.Position + Vector3.new(5, 4, 3)
    end
    
    -- Move heads up and down
    for i, v in pairs(validTargets) do 
        v.Head.Position = hrp.Position + Vector3.new(5, 1.5, 3)
        task.wait(0.1)
        v.Head.Position = hrp.Position + Vector3.new(5, 4, 3)
    end
end

-- Create a loop using RunService
local RunService = game:GetService("RunService")
local connection = nil

-- Toggle function
local function toggleFeature()
    if enabled then
        -- Start the loop if not already running
        if not connection then
            connection = RunService.Heartbeat:Connect(function()
                task.spawn(moveHeads) -- Run in separate thread to avoid freezing
            end)
            print("Head movement started")
        end
    else
        -- Stop the loop
        if connection then
            connection:Disconnect()
            connection = nil
            print("Head movement stopped")
        end
    end
end

-- Button click handler
button.MouseButton1Click:Connect(function()
    enabled = not enabled -- Toggle the variable
    
    -- Update button appearance
    button.Text = enabled and "ON" or "OFF"
    button.BackgroundColor3 = enabled and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
    
    -- Toggle the feature
    toggleFeature()
end)
