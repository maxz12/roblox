-- Variables for target rotation
local currentTargetIndex = 1
local lastRotationTime = tick()

-- Move targets to their original positions when script ends
local function cleanup()
    for _, target in pairs(targetsPath:GetChildren()) do
        if target:GetAttribute("OriginalCFrame") then
            if target:IsA("BasePart") then
                target.CFrame = target:GetAttribute("OriginalCFrame")
            elseif target:IsA("Model") and target.PrimaryPart then
                target:SetPrimaryPartCFrame(target:GetAttribute("OriginalCFrame"))
            end
        end
    end
end

-- Store original positions on script start
for _, target in pairs(targetsPath:GetChildren()) do
    if target:IsA("BasePart") then
        target:SetAttribute("OriginalCFrame", target.CFrame)
    elseif target:IsA("Model") and target.PrimaryPart then
        target:SetAttribute("OriginalCFrame", target:GetPrimaryPartCFrame())
    end
end

-- Main update function to position targets
local function updateTargetPositions()
    if not config.enabled then return end
    
    local character = localPlayer.Character
    if not character then return end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Get target list
    local targets = targetsPath:GetChildren()
    if #targets == 0 then
        countLabel.Text = "Targets: 0 | Active: None"
        return
    end
    
    -- Check for target rotation
    local currentTime = tick()
    if currentTime - lastRotationTime >= config.rotationSpeed then
        currentTargetIndex = currentTargetIndex + 1
        if currentTargetIndex > #targets then
            currentTargetIndex = 1
        end
        lastRotationTime = currentTime
    end
    
    -- Forward direction and base position
    local forward = hrp.CFrame.LookVector
    local basePosition = hrp.Position + (forward * config.distance)
    
    -- Position all targets
    for i, target in ipairs(targets) do
        local targetPosition
        
        if i == currentTargetIndex then
            -- Current target in front
            targetPosition = basePosition
        else
            -- Calculate position behind the front target
            -- We'll put it directly behind, in the same line
            targetPosition = basePosition - (forward * config.stackOffset)
        end
        
        -- Set the target's position
        if target:IsA("BasePart") then
            target.CFrame = CFrame.new(targetPosition, targetPosition + forward)
        elseif target:IsA("Model") and target.PrimaryPart then
            -- Calculate offset from primary part to the model's pivot
            local offset = target:GetPrimaryPartCFrame().Position - target.PrimaryPart.Position
            target:SetPrimaryPartCFrame(CFrame.new(targetPosition + offset, targetPosition + offset + forward))
        end
    end
    
    -- Update the status label
    local currentTarget = targets[currentTargetIndex]
    local targetName = currentTarget and currentTarget.Name or "Unknown"
    countLabel.Text = "Targets: " .. #targets .. " | Active: " .. targetName .. " (#" .. currentTargetIndex .. ")"
end

-- Connect to Heartbeat for smooth updates
RunService.Heartbeat:Connect(updateTargetPositions)

