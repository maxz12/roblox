    if mouseDown and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mousePos = UserInputService:GetMouseLocation()
        local btnPos = sliderBtn.AbsolutePosition
        local btnSize = sliderBtn.AbsoluteSize
        
        if mousePos.X >= btnPos.X and mousePos.X <= btnPos.X + btnSize.X then
            local relativeX = (mousePos.X - btnPos.X) / btnSize.X
            config.radius = math.max(3, math.min(config.maxRadius, relativeX * config.maxRadius))
            sliderFill.Size = UDim2.new(config.radius / config.maxRadius, 0, 1, 0)
            radiusLabel.Text = "Radius: " .. math.floor(config.radius * 10) / 10
        end
    end
end)

-- Function to get the center position of an object (part or model)
local function getObjectPosition(object)
    if object:IsA("BasePart") then
        return object.Position
    elseif object:IsA("Model") then
        if object.PrimaryPart then
            return object.PrimaryPart.Position
        else
            local parts = {}
            for _, part in pairs(object:GetDescendants()) do
                if part:IsA("BasePart") then
                    table.insert(parts, part)
                end
            end
            
            if #parts > 0 then
                local sum = Vector3.new(0, 0, 0)
                for _, part in pairs(parts) do
                    sum = sum + part.Position
                end
                return sum / #parts
            end
        end
    end
    
    -- Fallback
    return Vector3.new(0, 0, 0)
end

-- Function to position targets in a circle
local function positionTargets(center)
    if not center then return end
    
    -- Get all targets from the MatchTargets folder
    local targets = targetsPath:GetChildren()
    countLabel.Text = "Targets: " .. #targets
    
    -- If no targets, nothing to do
    if #targets == 0 then return end
    
    -- Position targets in a fixed circle
    for i, target in ipairs(targets) do
        -- Calculate position in static circle
        local targetAngle = (2 * math.pi * i / #targets) + angle
        
        -- Calculate offset using world coordinates
        local offsetX = math.cos(targetAngle) * config.radius
        local offsetZ = math.sin(targetAngle) * config.radius
        
        -- Position at that point
        local targetPos = center + Vector3.new(offsetX, 0, offsetZ)
        
        -- Make target face the center of the circle
        local lookDir = (center - targetPos).Unit
        
        -- Handle different object types
        if target:IsA("BasePart") then
            target.CFrame = CFrame.new(targetPos, targetPos + lookDir)
        elseif target:IsA("Model") then
            -- Try to use PrimaryPart if available
            if target.PrimaryPart then
                local offset = target:GetPrimaryPartCFrame().Position - target.PrimaryPart.Position
                target:SetPrimaryPartCFrame(CFrame.new(targetPos + offset, targetPos + offset + lookDir))
            else
                -- Try to move all parts if no PrimaryPart
                local originalPos = getObjectPosition(target)
                for _, part in pairs(target:GetDescendants()) do
                    if part:IsA("BasePart") then
                        local relativePos = part.Position - originalPos
                        part.CFrame = CFrame.new(targetPos + relativePos, targetPos + relativePos + lookDir)
                    end
                end
            end
        end
    end
end

-- Real-time teleportation using Heartbeat
RunService.Heartbeat:Connect(function()
    -- Skip if disabled
    if not config.enabled then return end
    
    local character = localPlayer.Character
    if not character then return end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Always position targets every frame
    positionTargets(hrp.Position)
end)

