-- SecureCoreLoader.lua
-- This script loads SecureCoreModule as soon as possible.
local module = game.ServerScriptService:WaitForChild("SecureCoreModule", 5)
if not module then
	error("SecureCoreModule not found in ServerScriptService!")
end
local SecureCore = require(module)
print("[Server] SecureCoreModule loaded. Available commands:")
for action, _ in pairs(SecureCore.commands) do
	print("   -", action)
end
