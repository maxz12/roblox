--[[
    SecureCoreModule.lua
    --------------------
    This module provides secure, server-only functions for:
      • Encrypting and decrypting text.
      • Creating, verifying, and updating tokens (fingerprints) from data.
      • Generating a fingerprint for a script’s source.
      • Generating and checking a fingerprint for a Roblox object’s state.
      
    All security-critical operations run on the server.
    The client sends only simple requests via the RemoteEvent "CoreEvent".

    IMPORTANT:
      • Change PRIVATE_KEY to a strong, random value.
      • In production, remove or limit debug prints.
      
    NOTE:
      • For script integrity, the server can only read the .Source property of scripts
        that are accessible on the server (e.g. ModuleScripts in ServerScriptService).
      • The new object functions let you “store” an object’s state (a set of its properties)
        as a fingerprint, and then later check if that fingerprint has changed.
--]]

local HttpService = game:GetService("HttpService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

------------------------------------------------------------
-- Create (or reuse) the RemoteEvent "CoreEvent" automatically.
------------------------------------------------------------
local CoreEvent = ReplicatedStorage:FindFirstChild("CoreEvent")
if not CoreEvent then
	CoreEvent = Instance.new("RemoteEvent")
	CoreEvent.Name = "CoreEvent"
	CoreEvent.Parent = ReplicatedStorage
	print("[Server] CoreEvent created in ReplicatedStorage.")
end

------------------------------------------------------------
-- Module Setup & Global Variables
------------------------------------------------------------
local SecureCore = {}
SecureCore.commands = {}  -- Table to hold our command functions

-- DEBUG flag for extra output during development.
local DEBUG = true

-- PRIVATE_KEY for encryption/signing (CHANGE THIS for production!)
local PRIVATE_KEY = "YourStrongRandomSecretKey"
if DEBUG then
	print("[Server] PRIVATE_KEY is set.")
end

------------------------------------------------------------
-- Helper Functions
------------------------------------------------------------

-- getFingerprint returns the first 8 characters of a string.
local function getFingerprint(text)
	return string.sub(text, 1, 8)
end

-- xorEncrypt: A simple XOR-based transform (for demonstration only).
local function xorEncrypt(input, key)
	local output = {}
	for i = 1, #input do
		local inputByte = input:byte(i)
		local keyByte = key:byte(((i - 1) % #key) + 1)
		output[i] = string.char(bit32.bxor(inputByte, keyByte))
	end
	return table.concat(output)
end

------------------------------------------------------------
-- Command Functions
------------------------------------------------------------

--[[ 
    Command: Encrypt
    ----------------
    Input parameter: { plainText }
    Returns the "encrypted" version of the text.
--]]
function SecureCore.commands.Encrypt(player, params)
	local plainText = params[1]
	if type(plainText) ~= "string" or plainText == "" then
		return { success = false, message = "Encrypt: No valid plain text provided." }
	end
	local encrypted = xorEncrypt(plainText, PRIVATE_KEY)
	if DEBUG then
		print("[Server][Encrypt] Fingerprint =", getFingerprint(encrypted))
	end
	return { success = true, message = "Text encrypted.", data = encrypted }
end

--[[ 
    Command: Decrypt
    ----------------
    Input parameter: { encryptedText }
    Returns the original plain text.
--]]
function SecureCore.commands.Decrypt(player, params)
	local encryptedText = params[1]
	if type(encryptedText) ~= "string" or encryptedText == "" then
		return { success = false, message = "Decrypt: No valid encrypted text provided." }
	end
	local decrypted = xorEncrypt(encryptedText, PRIVATE_KEY)
	return { success = true, message = "Text decrypted.", data = decrypted }
end

--[[ 
    Command: TokenCreate
    ---------------------
    Input parameter: { data }
    Packages the given data (for example, a script’s source or configuration info)
    with a timestamp into a JSON token, then “signs” it.
    Returns the token and its signature.
--]]
function SecureCore.commands.TokenCreate(player, params)
	local data = params[1]
	if type(data) ~= "string" or data == "" then
		return { success = false, message = "TokenCreate: No valid data provided." }
	end
	local tokenTable = { timestamp = os.time(), data = data }
	local tokenJson = HttpService:JSONEncode(tokenTable)
	local signature = xorEncrypt(tokenJson, PRIVATE_KEY)
	if DEBUG then
		print("[Server][TokenCreate] Token FP =", getFingerprint(tokenJson))
	end
	return { success = true, message = "Token created.", data = { token = tokenJson, signature = signature } }
end

--[[ 
    Command: TokenVerify
    ---------------------
    Input parameters: { token, signature }
    Recomputes the expected signature from the token and compares it to the provided signature.
    Returns whether the token is valid.
--]]
function SecureCore.commands.TokenVerify(player, params)
	local token = params[1]
	local signature = params[2]
	if not token or not signature then
		return { success = false, message = "TokenVerify: Token or signature missing." }
	end
	local expectedSignature = xorEncrypt(token, PRIVATE_KEY)
	if DEBUG then
		print("[Server][TokenVerify] Expected FP =", getFingerprint(expectedSignature))
	end
	if signature == expectedSignature then
		return { success = true, message = "Token is valid." }
	else
		return { success = false, message = "Token is invalid." }
	end
end

--[[ 
    Command: UpdateToken
    ---------------------
    Input parameters: { oldToken, oldSignature, newData }
    Verifies the existing token's signature. If valid, creates a new token with the updated data.
    Returns the new token and its signature.
--]]
function SecureCore.commands.UpdateToken(player, params)
	local oldToken = params[1]
	local oldSignature = params[2]
	local newData = params[3]

	if type(oldToken) ~= "string" or type(oldSignature) ~= "string" or type(newData) ~= "string" or newData == "" then
		return { success = false, message = "UpdateToken: Invalid or missing parameters." }
	end

	-- Verify the existing token first.
	local expectedSignature = xorEncrypt(oldToken, PRIVATE_KEY)
	if expectedSignature ~= oldSignature then
		return { success = false, message = "UpdateToken: Token signature invalid." }
	end

	-- Create a new token with the updated data.
	local tokenTable = { timestamp = os.time(), data = newData }
	local newTokenJson = HttpService:JSONEncode(tokenTable)
	local newSignature = xorEncrypt(newTokenJson, PRIVATE_KEY)

	if DEBUG then
		print("[Server][UpdateToken] New Token FP =", getFingerprint(newTokenJson))
	end
	return { success = true, message = "Token updated successfully.", data = { token = newTokenJson, signature = newSignature } }
end

--[[ 
    Command: ScriptFingerprint
    ---------------------------
    Input parameter: { scriptName }
    Searches for a script (first in ServerScriptService, then in StarterPlayerScripts) and
    returns a fingerprint of its .Source property.
--]]
function SecureCore.commands.ScriptFingerprint(player, params)
	local scriptName = params[1]
	if not scriptName then
		return { success = false, message = "ScriptFingerprint: No script name provided." }
	end
	local scriptObj = game.ServerScriptService:FindFirstChild(scriptName)
	if not scriptObj and game.StarterPlayer and game.StarterPlayer:FindFirstChild("StarterPlayerScripts") then
		scriptObj = game.StarterPlayer.StarterPlayerScripts:FindFirstChild(scriptName)
	end
	if not scriptObj then
		return { success = false, message = "ScriptFingerprint: Script '" .. scriptName .. "' not found." }
	end
	local source = scriptObj.Source
	if not source or source == "" then
		return { success = false, message = "ScriptFingerprint: Unable to read source for '" .. scriptName .. "'." }
	end
	local fingerprint = getFingerprint(xorEncrypt(source, PRIVATE_KEY))
	if DEBUG then
		print("[Server][ScriptFingerprint] Script '" .. scriptName .. "' FP =", fingerprint)
	end
	return { success = true, message = "Script fingerprint computed.", data = fingerprint }
end

--[[ 
    Command: ScriptCheck
    ---------------------
    Input parameters: { scriptName, expectedFingerprint }
    Compares the current fingerprint of the specified script (by reading its .Source) with the expected fingerprint.
--]]
function SecureCore.commands.ScriptCheck(player, params)
	local scriptName = params[1]
	local expectedFP = params[2]
	if not scriptName or not expectedFP then
		return { success = false, message = "ScriptCheck: Missing script name or expected fingerprint." }
	end
	local scriptObj = game.ServerScriptService:FindFirstChild(scriptName)
	if not scriptObj and game.StarterPlayer and game.StarterPlayer:FindFirstChild("StarterPlayerScripts") then
		scriptObj = game.StarterPlayer.StarterPlayerScripts:FindFirstChild(scriptName)
	end
	if not scriptObj then
		return { success = false, message = "ScriptCheck: Script '" .. scriptName .. "' not found." }
	end
	local source = scriptObj.Source
	if not source or source == "" then
		return { success = false, message = "ScriptCheck: Unable to read source for '" .. scriptName .. "'." }
	end
	local computedFP = getFingerprint(xorEncrypt(source, PRIVATE_KEY))
	if DEBUG then
		print("[Server][ScriptCheck] Script '" .. scriptName .. "': Expected FP =", expectedFP, "Computed FP =", computedFP)
	end
	if computedFP == expectedFP then
		return { success = true, message = "Script integrity verified." }
	else
		return { success = false, message = "Script integrity compromised. Expected: " .. expectedFP .. ", got: " .. computedFP }
	end
end

------------------------------------------------------------
-- NEW: Object (Userdata) Token Commands
------------------------------------------------------------

--[[ 
    Command: ObjectTokenCreate
    ----------------------------
    Input parameters: { location, objectName }
      • location: a string indicating a top-level service name (e.g., "Workspace", "ServerScriptService")
      • objectName: the name of the object to check.
    Finds the object and creates a fingerprint from key properties.
    For BaseParts, it includes Position, Size, and Color.
--]]
function SecureCore.commands.ObjectTokenCreate(player, params)
	local locationName = params[1]
	local objectName = params[2]
	if not locationName or not objectName then
		return { success = false, message = "ObjectTokenCreate: Missing location or object name." }
	end

	local parent = game:FindFirstChild(locationName)
	if not parent then
		return { success = false, message = "ObjectTokenCreate: Location '" .. locationName .. "' not found." }
	end

	local obj = parent:FindFirstChild(objectName)
	if not obj then
		return { success = false, message = "ObjectTokenCreate: Object '" .. objectName .. "' not found in " .. locationName .. "." }
	end

	local props = {
		Name = obj.Name,
		ClassName = obj.ClassName,
	}
	if obj:IsA("BasePart") then
		props.Position = tostring(obj.Position)
		props.Size = tostring(obj.Size)
		props.Color = tostring(obj.Color)
	end

	local propsJson = HttpService:JSONEncode(props)
	local fingerprint = getFingerprint(xorEncrypt(propsJson, PRIVATE_KEY))
	if DEBUG then
		print("[Server][ObjectTokenCreate] Fingerprint for " .. locationName .. "." .. objectName .. " =", fingerprint)
	end
	return { success = true, message = "Object token created.", data = fingerprint }
end

--[[ 
    Command: ObjectTokenCheck
    --------------------------
    Input parameters: { location, objectName, expectedFingerprint }
    Finds the specified object and computes its fingerprint,
    then compares it with the provided expected fingerprint.
--]]
function SecureCore.commands.ObjectTokenCheck(player, params)
	local locationName = params[1]
	local objectName = params[2]
	local expectedFingerprint = params[3]
	if not locationName or not objectName or not expectedFingerprint then
		return { success = false, message = "ObjectTokenCheck: Missing parameters." }
	end

	local parent = game:FindFirstChild(locationName)
	if not parent then
		return { success = false, message = "ObjectTokenCheck: Location '" .. locationName .. "' not found." }
	end

	local obj = parent:FindFirstChild(objectName)
	if not obj then
		return { success = false, message = "ObjectTokenCheck: Object '" .. objectName .. "' not found in " .. locationName .. "." }
	end

	local props = {
		Name = obj.Name,
		ClassName = obj.ClassName,
	}
	if obj:IsA("BasePart") then
		props.Position = tostring(obj.Position)
		props.Size = tostring(obj.Size)
		props.Color = tostring(obj.Color)
	end

	local propsJson = HttpService:JSONEncode(props)
	local currentFingerprint = getFingerprint(xorEncrypt(propsJson, PRIVATE_KEY))
	if DEBUG then
		print("[Server][ObjectTokenCheck] Current FP for " .. locationName .. "." .. objectName .. " =", currentFingerprint)
	end

	if currentFingerprint == expectedFingerprint then
		return { success = true, message = "Object token verified; state unchanged." }
	else
		return { success = false, message = "Object token mismatch. Expected: " .. expectedFingerprint .. ", got: " .. currentFingerprint }
	end
end

------------------------------------------------------------
-- Global Request Handler: Process incoming requests.
------------------------------------------------------------
CoreEvent.OnServerEvent:Connect(function(player, request)
	if type(request) ~= "table" or not request.action then
		warn("[Server] Malformed request from", player.Name)
		return
	end
	local action = request.action
	local params = request.params or {}
	if DEBUG then
		print("[Server] Request from", player.Name, "Action:", action)
	end
	local commandFunc = SecureCore.commands[action]
	if commandFunc and type(commandFunc) == "function" then
		local result = commandFunc(player, params)
		CoreEvent:FireClient(player, { success = result.success, message = result.message, data = result.data })
	else
		warn("[Server] Unknown action:", action, "from", player.Name)
		CoreEvent:FireClient(player, { success = false, message = "Unknown action." })
	end
end)

------------------------------------------------------------
-- Expose CoreEvent for external use if needed.
------------------------------------------------------------
SecureCore.CoreEvent = CoreEvent
return SecureCore
