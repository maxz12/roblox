local function getTimeAgo(timestamp)
    if not timestamp then return "Never" end
    
    local seconds = os.time() - timestamp
    
    if seconds < 5 then
        return "Just now"
    elseif seconds < 60 then
        return seconds .. "s ago"
    elseif seconds < 3600 then
        return math.floor(seconds / 60) .. "m ago"
    elseif seconds < 86400 then
        return math.floor(seconds / 3600) .. "h ago"
    else
        return math.floor(seconds / 86400) .. "d ago"
    end
end

local function clearResults()
    for _, child in pairs(ResultsList:GetChildren()) do
        if child:IsA("Frame") and child.Name ~= "ResultTemplate" then
            child:Destroy()
        end
    end
    ResultsList.CanvasSize = UDim2.new(0, 0, 0, 0)
    searchResults = {}
    lockStates = {}
    resultIdCounter = 0
end

local function updateResultsLabel()
    ResultsLabel.Text = "Results: (" .. #searchResults .. " found)"
end

local function valueToString(value)
    local valueType = type(value)
    if valueType == "string" then
        if #value > 30 then
            return string.sub(value, 1, 27) .. "..."
        else
            return value
        end
    elseif valueType == "number" or valueType == "boolean" then
        return tostring(value)
    elseif valueType == "table" then
        return "[Table]"
    elseif valueType == "function" then
        return "[Function]"
    elseif valueType == "userdata" then
        return "[UserData]"
    else
        return "[" .. valueType .. "]"
    end
end

local function convertValueToType(valueText, targetType)
    if targetType == "number" then
        return tonumber(valueText)
    elseif targetType == "boolean" then
        local lower = valueText:lower()
        if lower == "true" then
            return true
        elseif lower == "false" then
            return false
        else
            return nil
        end
    else
        -- For strings or other types, return as is
        return valueText
    end
end

local function highlightValueChange(valueTextBox)
    if not valueTextBox then return end
    
    local originalColor = valueTextBox.BackgroundColor3
    local originalTextColor = valueTextBox.TextColor3
    
    -- Highlight
    valueTextBox.BackgroundColor3 = HIGHLIGHT_COLOR
    valueTextBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    
    -- Update "Updated" label to "Just now" if possible
    local resultEntry = valueTextBox.Parent
    if resultEntry and resultEntry:FindFirstChild("UpdatedLabel") then
        resultEntry.UpdatedLabel.Text = "Just now"
    end
    
    -- Reset after a delay, but keep locked color if locked
    delay(highlightDuration, function()
        if valueTextBox then
            local resultName = valueTextBox.Parent.Name
            local resultId = tonumber(resultName:match("Result_(%d+)"))
            
            if resultId and lockStates[resultId] then
                valueTextBox.BackgroundColor3 = LOCKED_COLOR
            else
                valueTextBox.BackgroundColor3 = originalColor
            end
            
            valueTextBox.TextColor3 = originalTextColor
        end
    end)
end

local function setValueFromTextBox(resultId, textBox)
    -- Find the result by ID
    local result = nil
    for _, r in ipairs(searchResults) do
        if r.id == resultId then
            result = r
            break
        end
    end
    
    if not result then return false end
    
    -- If locked, don't allow changes
    if lockStates[resultId] then
        showStatus("Cannot change locked value: " .. tostring(result.key))
        textBox.Text = valueToString(lockedValues[resultId] or result.value)
        return false
    end
    
    local newValueText = textBox.Text
    local valueType = type(result.value)
    
    -- Try to convert to appropriate type
    local newValue = convertValueToType(newValueText, valueType)
    
    if newValue == nil and valueType ~= "string" then
        showStatus("Error: Could not convert '" .. newValueText .. "' to " .. valueType)
        -- Reset text box to current value
        textBox.Text = valueToString(result.value)
        return false
    end
    
    -- Set the value
    local success, err = pcall(function()
        result.table[result.key] = newValue
        result.value = newValue
        result.lastUpdated = os.time()
    end)
    
    if success then
        showStatus("Value changed successfully: " .. tostring(result.key))
        highlightValueChange(textBox)
        return true
    else
        showStatus("Error: " .. tostring(err))
        -- Reset text box to current value
        textBox.Text = valueToString(result.value)
        return false
    end
end

local function updateLockDisplay(resultId)
    local resultEntry = ResultsList:FindFirstChild("Result_" .. resultId)
    if not resultEntry then return end
    
    local isLocked = lockStates[resultId]
    
    -- Update lock button
    local lockButton = resultEntry:FindFirstChild("LockButton")
    if lockButton then
        if isLocked then
            lockButton.Text = "🔒"
            lockButton.BackgroundColor3 = Color3.fromRGB(180, 70, 70)
            lockButton.BorderColor3 = Color3.fromRGB(200, 100, 100)
            lockButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            lockButton.Text = "🔓"
            lockButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            lockButton.BorderColor3 = Color3.fromRGB(100, 100, 100)
            lockButton.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
    end
    
    -- Update value text box
    local valueTextBox = resultEntry:FindFirstChild("ValueTextBox")
    if valueTextBox then
        if isLocked then
            valueTextBox.BackgroundColor3 = LOCKED_COLOR
        else
            valueTextBox.BackgroundColor3 = NORMAL_COLOR
        end
    end
end

local function toggleLockValue(resultId)
    -- Toggle locked state
    local isNowLocked = not lockStates[resultId]
    lockStates[resultId] = isNowLocked
    
    -- Find the result
    local result = nil
    for _, r in ipairs(searchResults) do
        if r.id == resultId then
            result = r
            break
        end
    end
    
    if result then
        -- If we're locking, store the current value
        if isNowLocked then
            lockedValues[resultId] = result.value
        else
            lockedValues[resultId] = nil
        end
        
        -- Update the lock display
        updateLockDisplay(resultId)
        
        -- Show status message
        local actionText = isNowLocked and "Locked" or "Unlocked"
        showStatus(actionText .. " value: " .. tostring(result.key))
    end
end

local function showChangeAllUI()
    ChangeAllUI.Visible = true
    NewValueInput.Text = "999"
    NewValueInput:CaptureFocus()
end

local function applyChangeAll()
    local newValueText = NewValueInput.Text
    local successCount = 0
    local failCount = 0
    local lockedCount = 0
    local currentTime = os.time()
    
    for _, result in ipairs(searchResults) do
        -- Skip locked values
        if lockStates[result.id] then
            lockedCount = lockedCount + 1
            continue
        end
        
        local valueType = type(result.value)
        local newValue = convertValueToType(newValueText, valueType)
        
        if newValue ~= nil or valueType == "string" then
            local success = pcall(function()
                result.table[result.key] = newValue
                result.value = newValue
                result.lastUpdated = currentTime
                
                -- Update the text box in the UI
                local resultEntry = ResultsList:FindFirstChild("Result_" .. result.id)
                if resultEntry and resultEntry:FindFirstChild("ValueTextBox") then
                    resultEntry.ValueTextBox.Text = valueToString(newValue)
                    highlightValueChange(resultEntry.ValueTextBox)
                end
            end)
            
            if success then
                successCount = successCount + 1
            else
                failCount = failCount + 1
            end
        else
            failCount = failCount + 1
        end
    end
    
    showStatus("Changed " .. successCount .. " values. Failed: " .. failCount .. ". Locked: " .. lockedCount)
    ChangeAllUI.Visible = false
end

local function matchesSearchCriteria(key, value, searchValue, searchType)
    -- If key is not a string, convert it to string for searching
    local keyStr = tostring(key)
    
    -- For string values
    if type(value) == "string" then
        if searchType == "Contains" then
            return string.find(string.lower(keyStr), string.lower(searchValue)) ~= nil
        elseif searchType == "Exact Match" then
            return string.lower(keyStr) == string.lower(searchValue)
        elseif searchType == "Starts With" then
            return string.find(string.lower(keyStr), "^" .. string.lower(searchValue)) ~= nil
        elseif searchType == "Ends With" then
            return string.find(string.lower(keyStr), string.lower(searchValue) .. "$") ~= nil
        end
    -- For number values
    elseif type(value) == "number" and tonumber(searchValue) then
        local numSearchValue = tonumber(searchValue)
        if searchType == "Greater Than" then
            return value > numSearchValue
        elseif searchType == "Less Than" then
            return value < numSearchValue
        elseif searchType == "Exact Match" then
            return value == numSearchValue
        elseif searchType == "Contains" then
            -- Check if number contains the digits
            return string.find(tostring(value), searchValue) ~= nil
        end
    -- For boolean values
    elseif type(value) == "boolean" and (searchValue == "true" or searchValue == "false") then
        local boolSearchValue = searchValue == "true"
        if searchType == "Exact Match" or searchType == "Contains" then
            return value == boolSearchValue
        end
    end
    
    -- Default to checking the key if other checks didn't match
    if searchType == "Contains" then
        return string.find(string.lower(keyStr), string.lower(searchValue)) ~= nil
    elseif searchType == "Exact Match" then
        return string.lower(keyStr) == string.lower(searchValue)
    elseif searchType == "Starts With" then
        return string.find(string.lower(keyStr), "^" .. string.lower(searchValue)) ~= nil
    elseif searchType == "Ends With" then
        return string.find(string.lower(keyStr), string.lower(searchValue) .. "$") ~= nil
    end
    
    return false
end

-- Compare function for sorting
local function compareValues(a, b)
    -- Default return for when comparison isn't possible
    local defaultCompare = currentSortDirection == "Ascending"
    
    if currentSortColumn == "Key" then
        local aKey = tostring(a.key)
        local bKey = tostring(b.key)
        
        if currentSortDirection == "Ascending" then
            return string.lower(aKey) < string.lower(bKey)
        else
            return string.lower(aKey) > string.lower(bKey)
        end
    elseif currentSortColumn == "Value" then
        local aType = type(a.value)
        local bType = type(b.value)
        
        if aType == bType then
            if aType == "number" or aType == "boolean" then
                if currentSortDirection == "Ascending" then
                    return a.value < b.value
                else
                    return a.value > b.value
                end
            else
                local aStr = valueToString(a.value)
                local bStr = valueToString(b.value)
                if currentSortDirection == "Ascending" then
                    return aStr < bStr
                else
                    return aStr > bStr
                end
            end
        else
            -- Different types, sort by type name
            if currentSortDirection == "Ascending" then
                return aType < bType
            else
                return aType > bType
            end
        end
    elseif currentSortColumn == "Type" then
        if currentSortDirection == "Ascending" then
            return type(a.value) < type(b.value)
        else
            return type(a.value) > type(b.value)
        end
    elseif currentSortColumn == "Updated" then
        local aTime = a.lastUpdated or 0
        local bTime = b.lastUpdated or 0
        if currentSortDirection == "Ascending" then
            return aTime < bTime
        else
            return aTime > bTime
        end
    else -- Index
        if currentSortDirection == "Ascending" then
            return a.index < b.index
        else
            return a.index > b.index
        end
    end
    
    return defaultCompare
end

-- Update header text to show sorting state
local function updateSortHeaders()
    local headers = {
        {header = IndexHeader, name = "Index"},
        {header = KeyHeader, name = "Key"},
        {header = ValueHeader, name = "Value"},
        {header = TypeHeader, name = "Type"},
        {header = UpdatedHeader, name = "Updated"}
    }
    
    for _, item in ipairs(headers) do
        if item.name == currentSortColumn then
            item.header.Text = item.name .. (currentSortDirection == "Ascending" and " ↑" or " ↓")
            item.header.TextColor3 = Color3.fromRGB(255, 255, 255) -- Highlight active sort
        else
            item.header.Text = item.name
            item.header.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
    end
end

-- Function to sort and reposition results
local function sortResults()
    -- Sort the results array
    table.sort(searchResults, compareValues)
    
    -- Update the UI to reflect the new order
    for i, result in ipairs(searchResults) do
        result.index = i
        local resultEntry = ResultsList:FindFirstChild("Result_" .. result.id)
        if resultEntry then
            resultEntry.IndexLabel.Text = tostring(i)
            resultEntry.Position = UDim2.new(0, 5, 0, (i - 1) * 35)
        end
    end
    
    -- Update the sort indicators in the headers
    updateSortHeaders()
end

-- Function to toggle the sort direction or column
local function toggleSort(column)
    if currentSortColumn == column then
        -- Toggle direction if same column
        currentSortDirection = currentSortDirection == "Ascending" and "Descending" or "Ascending"
    else
        -- Change column and set default direction
        currentSortColumn = column
        currentSortDirection = "Ascending"
    end
    
    sortResults()
    showStatus("Sorted by " .. column .. " (" .. currentSortDirection .. ")")
end

-- Update all displayed values from their source tables
local function updateDisplayedValues()
    local changedCount = 0
    local lockedEnforcedCount = 0
    local timeNow = os.time()
    
    for _, result in ipairs(searchResults) do
        -- Handle locked values first - enforce the locked value
        if lockStates[result.id] then
            local lockedValue = lockedValues[result.id]
            
            -- If the current value doesn't match the locked value, force it back
            if result.table[result.key] ~= lockedValue then
                -- Restore the locked value
                pcall(function()
                    result.table[result.key] = lockedValue
                    lockedEnforcedCount = lockedEnforcedCount + 1
                end)
            end
            
            -- Skip further processing for locked values
            continue
        end
        
        -- For unlocked values, check for changes (same as before)
        local currentValue = result.table[result.key]
        
        -- Check if the value has changed
        if currentValue ~= result.value then
            result.value = currentValue
            result.lastUpdated = timeNow
            changedCount = changedCount + 1
            
            -- Update the UI if it exists
            local resultEntry = ResultsList:FindFirstChild("Result_" .. result.id)
            if resultEntry and resultEntry:FindFirstChild("ValueTextBox") then
                resultEntry.ValueTextBox.Text = valueToString(currentValue)
                highlightValueChange(resultEntry.ValueTextBox)
            end
        end
        
        -- Update time ago labels
        local resultEntry = ResultsList:FindFirstChild("Result_" .. result.id)
        if resultEntry and resultEntry:FindFirstChild("UpdatedLabel") and result.lastUpdated then
            resultEntry.UpdatedLabel.Text = getTimeAgo(result.lastUpdated)
        end
    end
    
    if changedCount > 0 then
        showStatus(changedCount .. " values updated automatically" .. 
                  (lockedEnforcedCount > 0 and ", " .. lockedEnforcedCount .. " locked values enforced" or ""))
        
        -- If sorting by "Updated" column, resort
        if currentSortColumn == "Updated" then
            sortResults()
        end
    elseif lockedEnforcedCount > 0 then
        showStatus(lockedEnforcedCount .. " locked values enforced")
    end
    
    return changedCount
end


-- Toggle auto update feature
local function toggleAutoUpdate()
    isAutoUpdateEnabled = not isAutoUpdateEnabled
    
    if isAutoUpdateEnabled then
        AutoUpdateToggle.Text = "Auto Update: ON"
        AutoUpdateToggle.BackgroundColor3 = Color3.fromRGB(70, 130, 70)
        
        -- Setup the update connection if it doesn't exist
        if not updateConnection and #searchResults > 0 then
            lastUpdateTime = tick() -- Use tick() instead of os.time() for higher precision
            updateConnection = RunService.Heartbeat:Connect(function()
                -- Update based on the updateInterval (now in seconds with decimal precision)
                if tick() - lastUpdateTime >= updateInterval then
                    updateDisplayedValues()
                    lastUpdateTime = tick()
                end
            end)
        end
    else
        AutoUpdateToggle.Text = "Auto Update: OFF"
        AutoUpdateToggle.BackgroundColor3 = Color3.fromRGB(130, 70, 70)
        
        -- Disconnect the update
        if updateConnection then
            updateConnection:Disconnect()
            updateConnection = nil
        end
    end
end

-- Create a result entry in the UI
local function createResultEntry(result, index)
    local newResult = ResultTemplate:Clone()
    newResult.Name = "Result_" .. result.id
    newResult.IndexLabel.Text = tostring(index)
    newResult.KeyLabel.Text = tostring(result.key)
    newResult.ValueTextBox.Text = valueToString(result.value)
    newResult.TypeLabel.Text = type(result.value)
    newResult.UpdatedLabel.Text = "Just now"
    newResult.Visible = true
    newResult.Position = UDim2.new(0, 5, 0, (index - 1) * 35)
    newResult.Parent = ResultsList
    
    -- Store the result ID in the button itself using attributes
    -- This ensures the event handler always has the correct ID
    newResult.LockButton:SetAttribute("ResultId", result.id)
    
    -- Set up the lock button click handler
    newResult.LockButton.MouseButton1Click:Connect(function()
        local id = newResult.LockButton:GetAttribute("ResultId")
        toggleLockValue(id)
    end)
    
    -- Set up the value text box to update the value when it loses focus
    newResult.ValueTextBox:SetAttribute("ResultId", result.id)
    newResult.ValueTextBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            local id = newResult.ValueTextBox:GetAttribute("ResultId")
            setValueFromTextBox(id, newResult.ValueTextBox)
        end
    end)
    
    return newResult
end

-- Function to refresh all search results with the current search criteria
local function searchGC()
    clearResults()
    showStatus("Searching...")
    
    local searchValue = SearchInput.Text
    local count = 0
    local tableCount = 0
    local currentTime = os.time()
    
    -- Get all GC objects
    local gcObjects = getgc(true)
    
    -- Loop through all GC objects
    for _, obj in next, gcObjects do
        if type(obj) == "table" then
            tableCount = tableCount + 1
            
            -- Scan each table
            for key, value in pairs(obj) do
                local valueType = type(value)
                
                -- Filter by type if needed
                if selectedType == "All Types" or valueType == selectedType then
                    -- Check if it matches search criteria
                    if searchValue == "" or matchesSearchCriteria(key, value, searchValue, selectedSearchType) then
                        count = count + 1
                        
                        -- Create a unique ID for this result
                        resultIdCounter = resultIdCounter + 1
                        local resultId = resultIdCounter
                        
                        -- Store result
                        local result = {
                            id = resultId,
                            index = count,
                            table = obj,
                            key = key,
                            value = value,
                            lastUpdated = currentTime
                        }
                        
                        table.insert(searchResults, result)
                        
                        -- Initialize lock state (unlocked by default)
                        lockStates[resultId] = false
                        
                        -- Create the UI element
                        createResultEntry(result, count)
                        
                        -- Limit results to prevent UI lag
                        if count >= 1000 then
                            showStatus("Reached maximum results (1000). Try refining your search.")
                            break
                        end
                        
                        -- Update canvas size
                        ResultsList.CanvasSize = UDim2.new(0, 0, 0, count * 35)
                    end
                end
            end
            
            -- If we reached the limit, break out of outer loop too
            if count >= 1000 then
                break
            end
        end
    end
    
    -- Apply the initial sort
    sortResults()
    
    updateResultsLabel()
    showStatus("Found " .. count .. " results in " .. tableCount .. " tables")
    
    -- Enable/disable Change All button based on results
    ChangeAllButton.Visible = (count > 0)
    
    -- Set up auto-update if enabled
    if isAutoUpdateEnabled and count > 0 and not updateConnection then
        lastUpdateTime = tick() -- Use tick() instead of os.time()
        updateConnection = RunService.Heartbeat:Connect(function()
            if tick() - lastUpdateTime >= updateInterval then
                updateDisplayedValues()
                lastUpdateTime = tick()
            end
        end)
    elseif count == 0 and updateConnection then
        updateConnection:Disconnect()
        updateConnection = nil
    end
end

local function toggleMinimize()
