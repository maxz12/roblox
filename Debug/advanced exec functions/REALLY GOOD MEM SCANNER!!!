    if isMinimized then
        MainFrame.Visible = false
        MinimizedFrame.Visible = true
    else
        MainFrame.Visible = true
        MinimizedFrame.Visible = false
    end
end

local function toggleVisibility()
    isVisible = not isVisible
    
    GCExplorer.Enabled = isVisible
    
    -- If toggling back to visible, also restore the correct minimized state
    if isVisible then
        if isMinimized then
            MainFrame.Visible = false
            MinimizedFrame.Visible = true
        else
            MainFrame.Visible = true
            MinimizedFrame.Visible = false
        end
    end
end

