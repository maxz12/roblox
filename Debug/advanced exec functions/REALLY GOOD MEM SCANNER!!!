-- Create the main GUI in CoreGui
local GCExplorer = Instance.new("ScreenGui")
GCExplorer.Name = "GCExplorer"
GCExplorer.ResetOnSpawn = false
GCExplorer.DisplayOrder = 999
GCExplorer.IgnoreGuiInset = true

-- Try to place in CoreGui, fall back to PlayerGui if not possible
local success = pcall(function()
    GCExplorer.Parent = CoreGui
end)

if not success then
    GCExplorer.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
    warn("CoreGui placement failed. Placed in PlayerGui instead.")
end

