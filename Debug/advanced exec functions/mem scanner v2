        errorTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
        errorTitle.Font = Enum.Font.SourceSansBold
        errorTitle.TextSize = 14
        errorTitle.Text = "Memory Scanner Error"
        errorTitle.Parent = errorFrame
        
        local errorText = Instance.new("TextLabel")
        errorText.Size = UDim2.new(1, -20, 1, -35)
        errorText.Position = UDim2.new(0, 10, 0, 30)
        errorText.BackgroundTransparency = 1
        errorText.TextColor3 = Color3.fromRGB(255, 255, 255)
        errorText.Font = Enum.Font.SourceSans
        errorText.TextSize = 14
        errorText.Text = tostring(errorMsg)
        errorText.TextWrapped = true
        errorText.Parent = errorFrame
    end)
end
