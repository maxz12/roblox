    -- Try to decompile a function safely
    local function safeDecompile(func)
        if not canDecompile then
            return "-- Decompilation not available in this exploit\n-- Function: " .. (selectedFunctionInfo.name or "anonymous")
        end
        
        local success, result = pcall(function()
            if decompile then
                return decompile(func)
            elseif syn and syn.decompile then
                return syn.decompile(func)
            end
        end)
        
        if success and result then
            return result
        else
            return "-- Failed to decompile function\n-- Error: " .. tostring(result or "Unknown error")
        end
    end
    
    -- Display function code
    local function displayFunctionCode(func, info)
        -- Update the code box
        codeBox.Text = "-- Loading function code..."
        
        -- Decompile in a separate thread to prevent freezing
        spawn(function()
            local source = safeDecompile(func)
            
            -- Limit length if too long
            if #source > 50000 then
                source = string.sub(source, 1, 50000) .. "\n\n-- Code truncated (too long to display fully)"
            end
            
            codeBox.Text = source
        end)
        
        -- Set up the apply button
        applyCodeButton.MouseButton1Click:Connect(function()
            local customCode = codeBox.Text
            
            -- Only proceed if hookfunction is available
            if canHookFunction then
                local success, result = pcall(function()
                    -- Try to create the replacement function
                    local newFunc = loadstring("return function(...)\n" .. customCode .. "\nend")()
                    
                    -- Apply the hook
                    local original = hookfunction(func, newFunc)
                    hookedFunctions[func] = original
                    
                    -- Update indicators
                    for _, child in pairs(ResultsList:GetChildren()) do
                        if child:IsA("Frame") then
                            local indicator = child:FindFirstChild("HookIndicator")
                            if indicator then
                                indicator.BackgroundColor3 = child.BackgroundTransparency < 0.5 and 
                                                            Color3.fromRGB(60, 200, 60) or
                                                            Color3.fromRGB(80, 80, 85)
                            end
                        end
                    end
                    
                    return "Successfully applied custom code hook"
                end)
                
                if success then
                    updateStatus(result)
                else
                    updateStatus("Error hooking function: " .. tostring(result))
                end
            else
                updateStatus("hookfunction not available in this exploit")
            end
        end)
    end
    
