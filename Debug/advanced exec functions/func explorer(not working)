    -- Search for functions containing the search text
    local function searchFunctions()
        -- Cancel ongoing search if any
        if isSearching then
            shouldCancelSearch = true
            wait(0.1) -- Give time for current search to cancel
        end
        
        isSearching = true
        shouldCancelSearch = false
        
        -- Clear results
        for _, child in pairs(ResultsList:GetChildren()) do
            if not child:IsA("UIListLayout") then
                child:Destroy()
            end
        end
        
        local searchText = string.lower(SearchBox.Text)
        
        if searchText == "" then
            updateStatus("Please enter a search term")
            isSearching = false
            return
        end
        
        updateStatus("Searching for '" .. searchText .. "'...")
        
        -- Collect garbage collected objects
        local gcObjects = {}
        pcall(function()
            gcObjects = getgc()
        end)
        
        local functions = {}
        local count = 0
        local processedCount = 0
        local totalObjects = #gcObjects
        
        -- Process objects in chunks
        spawn(function()
            -- Pre-filter to get only functions
            local funcObjects = {}
            for i, v in ipairs(gcObjects) do
                if type(v) == "function" then
                    table.insert(funcObjects, v)
                end
                
                -- Update status occasionally
                if i % 1000 == 0 then
                    updateStatus("Pre-filtering functions... " .. math.floor(i/totalObjects*100) .. "%")
                    wait(0.01)
                    
                    -- Check for cancellation
                    if shouldCancelSearch then
                        updateStatus("Search cancelled")
                        isSearching = false
                        return
                    end
                end
            end
            
            updateStatus("Searching " .. #funcObjects .. " functions for '" .. searchText .. "'...")
            
            -- Process functions in chunks
            for chunkStart = 1, #funcObjects, SEARCH_CHUNK_SIZE do
                local chunkEnd = math.min(chunkStart + SEARCH_CHUNK_SIZE - 1, #funcObjects)
                
                for i = chunkStart, chunkEnd do
                    local func = funcObjects[i]
                    processedCount = processedCount + 1
                    
                    -- Safe info gathering
                    local success, info = pcall(function()
                        return debug.getinfo(func)
                    end)
                    
                    if success and info then
                        local matchFound = false
                        
                        -- Check function name
                        if info.name and string.lower(info.name):find(searchText, 1, true) then
                            matchFound = true
                        end
                        
                        -- Only check upvalues if no match found in name
                        if not matchFound then
                            -- Check upvalues with error handling
                            pcall(function()
                                for j = 1, UPVALUE_FETCH_LIMIT do
                                    local name, value = debug.getupvalue(func, j)
                                    if not name then break end
                                    
                                    -- Check upvalue name
                                    if string.lower(name):find(searchText, 1, true) then
                                        matchFound = true
                                        break
                                    end
                                    
                                    -- Check upvalue string value
                                    if type(value) == "string" and string.lower(value):find(searchText, 1, true) then
                                        matchFound = true
                                        break
                                    end
                                end
                            end)
                        end
                        
                        if matchFound then
                            table.insert(functions, {
                                func = func,
                                info = info
                            })
                            
                            count = count + 1
                            
                            if count % 10 == 0 then
                                updateStatus("Found " .. count .. " matches so far... (" .. 
                                    math.floor(processedCount/#funcObjects*100) .. "% scanned)")
                            end
                            
                            if count >= MAX_RESULTS then
                                break
                            end
                        end
                    end
                end
                
                -- Update status between chunks
                updateStatus("Processed " .. processedCount .. "/" .. #funcObjects .. 
                    " functions, found " .. count .. " matches...")
                
                -- Wait between chunks to prevent timeout
                wait(SEARCH_DELAY)
                
                -- Check if we should cancel the search
                if shouldCancelSearch then
                    updateStatus("Search cancelled")
                    isSearching = false
                    return
                end
                
                -- Stop if we hit the max results
                if count >= MAX_RESULTS then
                    break
                end
            end
            
            -- Sort functions by name
            table.sort(functions, function(a, b)
                local nameA = a.info.name or ""
                local nameB = b.info.name or ""
                return nameA < nameB
            end)
            
            -- Create result items with delays to prevent freezing
            for i, data in ipairs(functions) do
                -- Create in chunks of 10
                createResultItem(data.func, data.info, i)
                
                if i % 10 == 0 then
                    wait(0.01)
                    
                    -- Check if we should cancel
                    if shouldCancelSearch then
                        updateStatus("Search cancelled while creating results")
                        isSearching = false
                        return
                    end
                end
            end
            
            -- Update results canvas size
            ResultsList.CanvasSize = UDim2.new(0, 0, 0, #functions * 42)
            
            -- Final status update
            if #functions == 0 then
                updateStatus("No functions found containing '" .. searchText .. "'")
            else
                updateStatus("Found " .. #functions .. " functions containing '" .. searchText .. "'")
            end
            
            isSearching = false
        end)
    end
    
