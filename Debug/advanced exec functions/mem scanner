    row.Parent = ResultsList
    
    -- Path label
    local pathLabel = Instance.new("TextLabel")
    pathLabel.Size = UDim2.new(0.6, -5, 1, 0)
    pathLabel.Position = UDim2.new(0, 5, 0, 0)
    pathLabel.BackgroundTransparency = 1
    pathLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    pathLabel.Font = Enum.Font.SourceSans
    pathLabel.TextSize = 14
    pathLabel.Text = path
    pathLabel.TextXAlignment = Enum.TextXAlignment.Left
    pathLabel.TextTruncate = Enum.TextTruncate.AtEnd
    pathLabel.Parent = row
    
    -- Value label
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0.2, -5, 1, 0)
    valueLabel.Position = UDim2.new(0.6, 0, 0, 0)
    valueLabel.BackgroundTransparency = 1
    valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    valueLabel.Font = Enum.Font.SourceSans
    valueLabel.TextSize = 14
    valueLabel.Text = formatValue(value)
    valueLabel.Parent = row
    
    -- Edit button
    local editButton = Instance.new("TextButton")
    editButton.Size = UDim2.new(0.1, -2, 1, -4)
    editButton.Position = UDim2.new(0.8, 0, 0, 2)
    editButton.BackgroundColor3 = Color3.fromRGB(70, 130, 180)
    editButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    editButton.Font = Enum.Font.SourceSansBold
    editButton.TextSize = 13
    editButton.Text = "Edit"
    editButton.Parent = row
    
    -- Lock button
    local isLocked = lockedValues[path] ~= nil
    local lockButton = Instance.new("TextButton")
    lockButton.Size = UDim2.new(0.1, -2, 1, -4)
    lockButton.Position = UDim2.new(0.9, 0, 0, 2)
    lockButton.BackgroundColor3 = isLocked and Color3.fromRGB(180, 60, 60) or Color3.fromRGB(60, 180, 60)
    lockButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    lockButton.Font = Enum.Font.SourceSansBold
    lockButton.TextSize = 13
    lockButton.Text = isLocked and "Unlock" or "Lock"
    lockButton.Parent = row
    
    -- Edit button functionality
    editButton.MouseButton1Click:Connect(function()
        if not setter then
            updateStatus("Cannot edit this value - no setter available")
            return
        end
        
        -- Create edit box
        local editBox = Instance.new("TextBox")
        editBox.Size = UDim2.new(0.2, -5, 1, -4)
        editBox.Position = UDim2.new(0.6, 0, 0, 2)
        editBox.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
        editBox.TextColor3 = Color3.fromRGB(255, 255, 255)
        editBox.Font = Enum.Font.SourceSans
        editBox.TextSize = 14
        editBox.Text = tostring(value)
        editBox.Parent = row
        
        -- Hide the value label
        valueLabel.Visible = false
        
        -- Handle focus lost event
        editBox.FocusLost:Connect(function(enterPressed)
            if enterPressed then
                -- Convert input to appropriate type
                local newValue
                if typeof(value) == "number" then
                    newValue = tonumber(editBox.Text)
                elseif typeof(value) == "boolean" then
                    newValue = editBox.Text:lower() == "true"
                else
                    newValue = editBox.Text
                end
                
                -- Try to set the value
                if newValue ~= nil then
                    local success = pcall(function()
                        setter(newValue)
                    end)
                    
                    if success then
                        valueLabel.Text = formatValue(newValue)
                        updateStatus("Value changed successfully")
                    else
                        updateStatus("Failed to set value")
                    end
                else
                    updateStatus("Invalid value format")
                end
            end
            
            -- Restore the value label
            valueLabel.Visible = true
            editBox:Destroy()
        end)
        
        -- Focus the edit box
        editBox:CaptureFocus()
    end)
    
    -- Lock button functionality
    lockButton.MouseButton1Click:Connect(function()
        if not setter then
            updateStatus("Cannot lock this value - no setter available")
            return
        end
        
        if lockedValues[path] then
            -- Unlock
            lockedValues[path] = nil
            lockButton.BackgroundColor3 = Color3.fromRGB(60, 180, 60)
            lockButton.Text = "Lock"
            updateStatus("Value unlocked: " .. path)
        else
            -- Lock
            lockedValues[path] = {
                value = value,
                setter = setter
            }
            lockButton.BackgroundColor3 = Color3.fromRGB(180, 60, 60)
            lockButton.Text = "Unlock"
            updateStatus("Value locked: " .. path)
        end
    end)
    
    return row
end

-- Scan for values
local function scanForValues()
    -- Don't start multiple scans
    if scanInProgress then return end
    scanInProgress = true
    
    -- Parse target value
    local targetValue = ValueInput.Text
    local target
    
    -- Convert based on selected type
    if selectedType == "Number" then
        target = tonumber(targetValue)
        if target == nil then
            updateStatus("Invalid number format")
            scanInProgress = false
            return
        end
    elseif selectedType == "String" then
        target = targetValue
    elseif selectedType == "Bool" then
        if targetValue:lower() == "true" then
            target = true
        elseif targetValue:lower() == "false" then
            target = false
        else
            updateStatus("Boolean must be 'true' or 'false'")
            scanInProgress = false
            return
        end
    end
    
    -- Clear existing results
    for _, child in pairs(ResultsList:GetChildren()) do
        child:Destroy()
    end
    
    -- Update UI for scanning
    ScanButton.Text = "Scanning..."
    ScanButton.BackgroundColor3 = Color3.fromRGB(180, 60, 60)
    ProgressBarBg.Visible = true
    updateProgress(0, "Starting scan...")
    
    -- Start scan in a separate thread
    spawn(function()
        local results = {}
        local startTime = tick()
        
        -- Function to check if values match
        local function valueMatches(value)
            if selectedType == "Number" and typeof(value) == "number" then
                return value == target
            elseif selectedType == "String" and typeof(value) == "string" then
                return value:find(target, 1, true) ~= nil
            elseif selectedType == "Bool" and typeof(value) == "boolean" then
                return value == target
            end
            return false
        end
        
        -- Check if scan should be cancelled
        local shouldCancelScan = false
        ScanButton.MouseButton1Click:Connect(function()
            if scanInProgress then
                shouldCancelScan = true
                ScanButton.Text = "Cancelling..."
            end
        end)
        
        -- SCAN PLAYER PROPERTIES - fast check for common values
        pcall(function()
            if shouldCancelScan then return end
            
            updateProgress(0.05, "Checking player properties...")
            
            local player = Players.LocalPlayer
            if player and player.Character then
                local character = player.Character
                
                -- Check humanoid properties
                if character:FindFirstChild("Humanoid") then
                    local humanoid = character.Humanoid
                    local props = {"WalkSpeed", "JumpPower", "Health", "MaxHealth"}
                    
                    for _, prop in ipairs(props) do
                        pcall(function()
                            local value = humanoid[prop]
                            if valueMatches(value) then
                                table.insert(results, {
                                    path = "Player.Character.Humanoid." .. prop,
                                    value = value,
                                    setter = function(newValue) humanoid[prop] = newValue end
                                })
                            end
                        end)
                    end
                end
            end
        end)
        
        -- SCAN UPVALUES IN GC
        if getgc and debug and debug.getupvalue and not shouldCancelScan then
            updateProgress(0.1, "Scanning function upvalues...")
            
            local functions = getgc()
            local totalFuncs = #functions
            
            for i, func in ipairs(functions) do
                if shouldCancelScan then break end
                
                if type(func) == "function" and islclosure and islclosure(func) then
                    pcall(function()
                        local info = debug.getinfo(func)
                        local funcName = info.name or "anonymous"
                        
                        for j = 1, 10 do -- Limit for performance
                            local success, name, value = pcall(function() 
                                return debug.getupvalue(func, j) 
                            end)
                            
                            if not success or not name then break end
                            
                            if valueMatches(value) then
                                table.insert(results, {
                                    path = "Function " .. funcName .. " upvalue " .. tostring(name),
                                    value = value,
                                    setter = function(newValue) debug.setupvalue(func, j, newValue) end
                                })
                            end
                        end
                    end)
                end
                
                -- Update progress periodically
                if i % 500 == 0 then
                    local progress = 0.1 + (i / totalFuncs * 0.4)
                    updateProgress(progress, string.format("Scanning functions: %d/%d, %d found", i, totalFuncs, #results))
                    wait() -- Prevent freezing
                end
            end
        end
        
        -- SCAN TABLES IN GC
        if getgc and not shouldCancelScan then
            updateProgress(0.5, "Scanning tables...")
            
            -- Collect tables
            local tables = {}
            pcall(function()
                for _, v in pairs(getgc(true)) do
                    if type(v) == "table" then
                        table.insert(tables, v)
                    end
                end
            end)
            
            local totalTables = #tables
            
            for i, tbl in ipairs(tables) do
                if shouldCancelScan then break end
                
                pcall(function()
                    -- Get table name
                    local tableName = "Table_" .. i
                    
                    if tbl.Name and type(tbl.Name) == "string" then
                        tableName = tbl.Name
                    elseif tbl.ClassName and type(tbl.ClassName) == "string" then
                        tableName = tbl.ClassName
                    end
                    
                    -- Scan table pairs
                    local keyCount = 0
                    for k, v in pairs(tbl) do
                        keyCount = keyCount + 1
                        if keyCount > 100 then break end -- Limit keys to prevent freezing
                        
                        if type(v) ~= "function" and type(v) ~= "userdata" and valueMatches(v) then
                            table.insert(results, {
                                path = tableName .. "." .. tostring(k),
                                value = v,
                                setter = function(newValue) tbl[k] = newValue end
                            })
                        end
                    end
                end)
                
                -- Update progress periodically
                if i % 200 == 0 then
                    local progress = 0.5 + (i / totalTables * 0.4)
                    updateProgress(progress, string.format("Scanning tables: %d/%d, %d found", i, totalTables, #results))
                    wait() -- Prevent freezing
                end
            end
        end
        
        -- Check if scan was cancelled
        if shouldCancelScan then
            updateStatus("Scan cancelled")
            ScanButton.Text = "Scan"
            ScanButton.BackgroundColor3 = Color3.fromRGB(70, 130, 180)
            ProgressBarBg.Visible = false
            scanInProgress = false
            return
        end
        
        -- DISPLAY RESULTS
        updateProgress(1, "Displaying results...")
        
        -- Limit maximum results
        local maxResults = math.min(200, #results)
        
        -- Create result items
        for i = 1, maxResults do
            local result = results[i]
            createResultItem(result.path, result.value, result.setter, i)
        end
        
        -- Update canvas size
        ResultsList.CanvasSize = UDim2.new(0, 0, 0, maxResults * 27)
        
        -- Finish scan
        local elapsedTime = tick() - startTime
        updateStatus(string.format("Found %d results in %.1f seconds", #results, elapsedTime))
        ScanButton.Text = "Scan"
        ScanButton.BackgroundColor3 = Color3.fromRGB(70, 130, 180)
        ProgressBarBg.Visible = false
        scanInProgress = false
    end)
end

