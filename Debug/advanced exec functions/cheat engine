    valueBox.Font = Enum.Font.SourceSans
    valueBox.TextSize = 13
    valueBox.Text = formatValue(resultData.value)
    valueBox.ClearTextOnFocus = false
    valueBox.Parent = row
    
    -- Handle value editing
    valueBox.FocusLost:Connect(function(enterPressed)
        if not resultData.setter then
            updateStatus("Cannot edit this value - no setter available")
            valueBox.Text = formatValue(resultData.value)
            return
        end
        
        local newValue = convertToType(valueBox.Text, typeof(resultData.value))
        if newValue ~= nil then
            local success = pcall(function()
                resultData.setter(newValue)
                resultData.value = newValue
            end)
            
            if success then
                updateStatus("Value updated successfully")
            else
                updateStatus("Failed to update value")
                valueBox.Text = formatValue(resultData.value)
            end
        else
            updateStatus("Invalid value format")
            valueBox.Text = formatValue(resultData.value)
        end
    end)
    
    -- Button container
    local buttonContainer = Instance.new("Frame")
    buttonContainer.Size = UDim2.new(0.35, -5, 1, 0)
    buttonContainer.Position = UDim2.new(0.65, 0, 0, 0)
    buttonContainer.BackgroundTransparency = 1
    buttonContainer.Parent = row
    
    -- Info button
    local infoButton = Instance.new("TextButton")
    infoButton.Size = UDim2.new(0.33, -2, 1, -4)
    infoButton.Position = UDim2.new(0, 0, 0, 2)
    infoButton.BackgroundColor3 = Color3.fromRGB(70, 130, 180)
    infoButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    infoButton.Font = Enum.Font.SourceSansBold
    infoButton.TextSize = 12
    infoButton.Text = "Info"
    infoButton.Parent = buttonContainer
    
    -- Lock button
    local isLocked = lockedValues[resultData.path] ~= nil
    local lockButton = Instance.new("TextButton")
    lockButton.Size = UDim2.new(0.67, -2, 1, -4)
    lockButton.Position = UDim2.new(0.33, 2, 0, 2)
    lockButton.BackgroundColor3 = isLocked and Color3.fromRGB(180, 60, 60) or Color3.fromRGB(60, 180, 60)
    lockButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    lockButton.Font = Enum.Font.SourceSansBold
    lockButton.TextSize = 12
    lockButton.Text = isLocked and "Unlock" or "Lock"
    lockButton.Parent = buttonContainer
    
    -- Info button click
    infoButton.MouseButton1Click:Connect(function()
        showValueDetails(resultData)
    end)
    
    -- Lock button behavior
    lockButton.MouseButton1Click:Connect(function()
        if not resultData.setter then
            updateStatus("Cannot lock this value - no setter available")
            return
        end
        
        if lockedValues[resultData.path] then
            -- Unlock
            lockedValues[resultData.path] = nil
            lockButton.BackgroundColor3 = Color3.fromRGB(60, 180, 60)
            lockButton.Text = "Lock"
            updateStatus("Value unlocked: " .. resultData.path)
        else
            -- Lock
            lockedValues[resultData.path] = {
                value = resultData.value,
                setter = resultData.setter
            }
            lockButton.BackgroundColor3 = Color3.fromRGB(180, 60, 60)
            lockButton.Text = "Unlock"
            updateStatus("Value locked: " .. resultData.path)
        end
    end)
    
    return row
end

-- Update all values for sequential scanning
local function updateAllValues()
    for _, resultData in ipairs(allValues) do
        -- Store previous value
        resultData.previousValue = resultData.value
        
        -- Get current value
        pcall(function()
            local currentValue = nil
            
            if resultData.valueGetter then
                currentValue = resultData.valueGetter()
            elseif resultData.object and resultData.key then
                currentValue = resultData.object[resultData.key]
            end
            
            if currentValue ~= nil then
                resultData.value = currentValue
            end
        end)
    end
end

-- Filter results based on scan type
local function filterResults(scanType, targetValue)
    local filtered = {}
    
    for _, resultData in ipairs(allValues) do
        local shouldInclude = false
        
        if scanType == "New Scan" then
            shouldInclude = true -- For new scans, include everything
        elseif scanType == "Changed" then
            shouldInclude = resultData.value ~= resultData.previousValue
        elseif scanType == "Unchanged" then
            shouldInclude = resultData.value == resultData.previousValue
        elseif scanType == "Increased" then
            if typeof(resultData.value) == "number" and typeof(resultData.previousValue) == "number" then
                shouldInclude = resultData.value > resultData.previousValue
            end
        elseif scanType == "Decreased" then
            if typeof(resultData.value) == "number" and typeof(resultData.previousValue) == "number" then
                shouldInclude = resultData.value < resultData.previousValue
            end
        end
        
        -- For exact value matching
        if targetValue ~= nil then
            if typeof(resultData.value) == typeof(targetValue) then
                shouldInclude = shouldInclude and resultData.value == targetValue
            else
                shouldInclude = false
            end
        end
        
        if shouldInclude then
            table.insert(filtered, resultData)
        end
    end
    
    return filtered
end

-- Lock all displayed values
local function lockAllValues()
    for _, resultData in ipairs(currentResults) do
        if resultData.setter then
            lockedValues[resultData.path] = {
                value = resultData.value,
                setter = resultData.setter
            }
        end
    end
    
    -- Update UI
    for _, child in pairs(ResultsList:GetChildren()) do
        if child:IsA("Frame") then
            for _, obj in pairs(child:GetDescendants()) do
                if obj:IsA("TextButton") and (obj.Text == "Lock" or obj.Text == "Unlock") then
                    obj.Text = "Unlock"
                    obj.BackgroundColor3 = Color3.fromRGB(180, 60, 60)
                end
            end
        end
    end
    
    updateStatus("All displayed values locked")
end

-- Unlock all values
local function unlockAllValues()
    lockedValues = {}
    
    -- Update UI
    for _, child in pairs(ResultsList:GetChildren()) do
        if child:IsA("Frame") then
            for _, obj in pairs(child:GetDescendants()) do
                if obj:IsA("TextButton") and (obj.Text == "Lock" or obj.Text == "Unlock") then
                    obj.Text = "Lock"
                    obj.BackgroundColor3 = Color3.fromRGB(60, 180, 60)
                end
            end
        end
    end
    
    updateStatus("All values unlocked")
end

-- Start a completely new scan session
local function startNewScan()
    -- Reset all data
    allValues = {}
    currentResults = {}
    hasFirstScan = false
    selectedScanType = "New Scan"
    
    -- Update UI
    for _, child in pairs(ResultsList:GetChildren()) do
        child:Destroy()
    end
    
    -- Reset scan buttons
    NewScanButton.BackgroundColor3 = Color3.fromRGB(70, 130, 180)
    ChangedButton.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    UnchangedButton.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    IncreasedButton.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    
    -- Hide lock/unlock buttons
    LockAllButton.Visible = false
    UnlockAllButton.Visible = false
    
    -- Reset scan counter
    resetScanCounter()
    
    -- Update status
    updateStatus("Ready for new scan session")
    
    -- Stop real-time updates
    if updateTimer then
        updateTimer:Disconnect()
        updateTimer = nil
    end
end

-- Perform scan
local function performScan()
    if scanInProgress then return end
    scanInProgress = true
    
    -- Clear existing results
    for _, child in pairs(ResultsList:GetChildren()) do
        child:Destroy()
    end
    
    -- Stop real-time updates during scan
    if updateTimer then
        updateTimer:Disconnect()
        updateTimer = nil
    end
    
    -- Parse target value based on type
    local targetValue = nil
    local targetText = ValueInput.Text
    
    if targetText ~= "" then
        if selectedValueType == "Number" then
            targetValue = tonumber(targetText)
            if targetValue == nil then
                updateStatus("Invalid number format")
                scanInProgress = false
                return
            end
        elseif selectedValueType == "String" then
            targetValue = targetText
        elseif selectedValueType == "Bool" then
            if targetText:lower() == "true" then
                targetValue = true
            elseif targetText:lower() == "false" then
                targetValue = false
            else
                updateStatus("Boolean must be true or false")
                scanInProgress = false
                return
            end
        end
    end
    
    -- Update UI
    ScanButton.Text = "Scanning..."
    updateStatus("Scanning in progress...")
    
    -- Increment scan counter
    updateScanCounter()
    
    -- Start scan in separate thread
    spawn(function()
        -- For sequential scans (not new scan)
        if selectedScanType ~= "New Scan" and hasFirstScan then
            -- Update current values
            updateAllValues()
            
            -- Filter based on scan type
            local filtered = filterResults(selectedScanType, targetValue)
            currentResults = filtered
            
            -- Display results
            local maxResults = math.min(200, #filtered)
            for i = 1, maxResults do
                createResultRow(filtered[i], i)
            end
            
            -- Update canvas size
            ResultsList.CanvasSize = UDim2.new(0, 0, 0, maxResults * 27)
            
            -- Show lock/unlock buttons
            LockAllButton.Visible = #filtered > 0
            UnlockAllButton.Visible = #filtered > 0
            
            -- Finish up
            updateStatus("Found " .. #filtered .. " results after filtering")
            ScanButton.Text = "Scan"
            scanInProgress = false
            
            -- Restart real-time updates if enabled
            if realTimeEnabled then
                startRealTimeUpdates()
            end
            
            return
        end
        
        -- For new scans
        local startTime = tick()
        local results = {}
        
        -- Function to check if value matches
        local function valueMatches(value)
            if targetValue == nil then return false end
            
            if selectedValueType == "Number" and typeof(value) == "number" then
                return value == targetValue
            elseif selectedValueType == "String" and typeof(value) == "string" then
                return value:find(targetValue, 1, true) ~= nil
            elseif selectedValueType == "Bool" and typeof(value) == "boolean" then
                return value == targetValue
            end
            return false
        end
        
        -- Scan 1: Player Properties
        pcall(function()
            updateStatus("Checking player properties...")
            
            local player = Players.LocalPlayer
            if player and player.Character then
                if player.Character:FindFirstChild("Humanoid") then
                    local humanoid = player.Character.Humanoid
                    local props = {"WalkSpeed", "JumpPower", "Health", "MaxHealth"}
                    
                    for _, prop in ipairs(props) do
                        pcall(function()
                            local value = humanoid[prop]
                            if valueMatches(value) then
                                table.insert(results, {
                                    path = "Player.Character.Humanoid." .. prop,
                                    value = value,
                                    previousValue = nil,
                                    object = humanoid,
                                    key = prop,
                                    setter = function(newValue) humanoid[prop] = newValue end,
                                    valueGetter = function() return humanoid[prop] end
                                })
                            end
                        end)
                    end
                end
                
                -- Check leaderstats
                if player:FindFirstChild("leaderstats") then
                    for _, stat in pairs(player.leaderstats:GetChildren()) do
                        pcall(function()
                            if stat:IsA("IntValue") or stat:IsA("NumberValue") or stat:IsA("StringValue") then
                                if valueMatches(stat.Value) then
                                    table.insert(results, {
                                        path = "Player.leaderstats." .. stat.Name,
                                        value = stat.Value,
                                        previousValue = nil,
                                        object = stat,
                                        key = "Value",
                                        setter = function(newValue) stat.Value = newValue end,
                                        valueGetter = function() return stat.Value end
                                    })
                                end
                            end
                        end)
                    end
                end
            end
        end)
        
        -- Scan 2: Function Upvalues
        if getgc and debug and debug.getupvalue then
            updateStatus("Scanning function upvalues...")
            
            local functions = getgc()
            local count = 0
            
            for _, func in ipairs(functions) do
                if type(func) == "function" and islclosure and islclosure(func) then
                    count = count + 1
                    
                    pcall(function()
                        local info = debug.getinfo(func)
                        local funcName = info.name or "anonymous"
                        
                        for j = 1, 10 do -- Limit to 10 upvalues for speed
                            local success, name, value = pcall(function()
                                return debug.getupvalue(func, j)
                            end)
                            
                            if not success or not name then break end
                            
                            if valueMatches(value) then
                                table.insert(results, {
                                    path = "Function " .. funcName .. " upvalue '" .. tostring(name) .. "'",
                                    value = value,
                                    previousValue = nil,
                                    object = func,
                                    upvalueIndex = j,
                                    setter = function(newValue) debug.setupvalue(func, j, newValue) end,
                                    valueGetter = function()
                                        local _, val = debug.getupvalue(func, j)
                                        return val
                                    end
                                })
                            end
                        end
                    end)
                    
                    -- Update status periodically
                    if count % 500 == 0 then
                        updateStatus("Scanning functions: " .. count .. " checked")
                        wait() -- Prevent freezing
                    end
                end
            end
        end
        
        -- Scan 3: Tables from GC
        if getgc then
            updateStatus("Scanning tables...")
            
            local tables = {}
            pcall(function()
                for _, v in pairs(getgc(true)) do
                    if type(v) == "table" then
                        table.insert(tables, v)
                    end
                end
            end)
            
            local count = 0
            
            for _, tbl in ipairs(tables) do
                count = count + 1
                
                pcall(function()
                    local tableName = "Table_" .. count
                    
                    if tbl.Name and type(tbl.Name) == "string" then
                        tableName = tbl.Name
                    elseif tbl.ClassName and type(tbl.ClassName) == "string" then
                        tableName = tbl.ClassName
                    end
                    
                    local keyCount = 0
                    for k, v in pairs(tbl) do
                        keyCount = keyCount + 1
                        if keyCount > 100 then break end -- Limit keys to prevent freezing
                        
                        if valueMatches(v) then
                            table.insert(results, {
                                path = tableName .. "." .. tostring(k),
                                value = v,
                                previousValue = nil,
                                object = tbl,
                                key = k,
                                setter = function(newValue) tbl[k] = newValue end,
                                valueGetter = function() return tbl[k] end
                            })
                        end
                    end
                end)
                
                -- Update status periodically
                if count % 200 == 0 then
                    updateStatus("Scanning tables: " .. count .. "/" .. #tables)
                    wait() -- Prevent freezing
                end
            end
        end
        
        -- Store results
        allValues = results
        currentResults = results
        
        -- Display results
        local maxResults = math.min(200, #results)
        for i = 1, maxResults do
            createResultRow(results[i], i)
        end
        
        -- Update canvas size
        ResultsList.CanvasSize = UDim2.new(0, 0, 0, maxResults * 27)
        
        -- Show lock/unlock buttons if we have results
        LockAllButton.Visible = #results > 0
        UnlockAllButton.Visible = #results > 0
        
        -- Finish up
        local elapsedTime = tick() - startTime
        updateStatus("Found " .. #results .. " matches in " .. string.format("%.2f", elapsedTime) .. " seconds")
        ScanButton.Text = "Scan"
        scanInProgress = false
        
        -- Enable sequential scanning if we found results
        hasFirstScan = #results > 0
        
        -- Update scan type button states
        if hasFirstScan then
            ChangedButton.BackgroundColor3 = ChangedButton == selectedScanType and Color3.fromRGB(70, 130, 180) or Color3.fromRGB(35, 35, 40)
            UnchangedButton.BackgroundColor3 = UnchangedButton == selectedScanType and Color3.fromRGB(70, 130, 180) or Color3.fromRGB(35, 35, 40)
            IncreasedButton.BackgroundColor3 = IncreasedButton == selectedScanType and Color3.fromRGB(70, 130, 180) or Color3.fromRGB(35, 35, 40)
        end
        
        -- Start real-time updates if enabled
        if realTimeEnabled then
            startRealTimeUpdates()
        end
    end)
end

-- Set up value locking loop
spawn(function()
    while wait(0.1) do
        for _, info in pairs(lockedValues) do
            pcall(function()
                info.setter(info.value)
            end)
        end
    end
end)

