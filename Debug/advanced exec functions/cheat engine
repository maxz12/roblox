-- Toggle real-time updates
local function toggleRealTimeUpdates()
    realTimeEnabled = not realTimeEnabled
    
    if realTimeEnabled then
        RealTimeToggle.Text = "ON"
        RealTimeToggle.BackgroundColor3 = Color3.fromRGB(60, 180, 60)
        
        -- Start real-time updates if we have results
        if #currentResults > 0 and not updateTimer then
            startRealTimeUpdates()
        end
    else
        RealTimeToggle.Text = "OFF"
        RealTimeToggle.BackgroundColor3 = Color3.fromRGB(180, 60, 60)
        
        -- Stop real-time updates
        if updateTimer then
            updateTimer:Disconnect()
            updateTimer = nil
        end
    end
end

-- Format value for display
local function formatValue(value)
    if value == nil then return "nil" end
    
    local valueType = typeof(value)
    if valueType == "number" then
        return string.format("%.2f", value)
    elseif valueType == "string" then
        if #value > 15 then
            return string.sub(value, 1, 12) .. "..."
        else
            return value
        end
    else
        return tostring(value)
    end
end

-- Convert input to appropriate type
local function convertToType(text, valueType)
    if valueType == "number" then
        return tonumber(text)
    elseif valueType == "boolean" then
        return text:lower() == "true"
    else
        return text
    end
end

-- Show value details
local function showValueDetails(resultData)
    -- Clear previous content
    for _, child in pairs(DetailsContent:GetChildren()) do
        child:Destroy()
    end
    
    local details = {}
    
    -- Basic details
    table.insert(details, {name = "Path", value = resultData.path})
    table.insert(details, {name = "Type", value = typeof(resultData.value)})
    table.insert(details, {name = "Current Value", value = tostring(resultData.value)})
    
    if resultData.previousValue ~= nil then
        table.insert(details, {name = "Previous Value", value = tostring(resultData.previousValue)})
    end
    
    -- Function/Script info
    if resultData.object and typeof(resultData.object) == "function" then
        pcall(function()
            local info = debug.getinfo(resultData.object)
            if info then
                if info.source then
                    table.insert(details, {name = "Source", value = info.source})
                end
                if info.linedefined then
                    table.insert(details, {name = "Line", value = tostring(info.linedefined)})
                end
                if info.what then
                    table.insert(details, {name = "Type", value = info.what})
                end
            end
        end)
    end
    
    -- Table info
    if resultData.object and typeof(resultData.object) == "table" then
        -- Show table keys
        local keyList = ""
        local count = 0
        pcall(function()
            for k, _ in pairs(resultData.object) do
                if count < 10 then -- Limit to 10 keys
                    keyList = keyList .. tostring(k) .. ", "
                    count = count + 1
                else
                    keyList = keyList .. "..."
                    break
                end
            end
        end)
        if keyList ~= "" then
            table.insert(details, {name = "Table Keys", value = keyList})
        end
    end
    
    -- Display the details
    for i, detail in ipairs(details) do
        -- Label
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.3, -10, 0, 20)
        label.Position = UDim2.new(0, 5, 0, (i-1) * 25 + 5)
        label.BackgroundTransparency = 1
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.Font = Enum.Font.SourceSansBold
        label.TextSize = 14
        label.Text = detail.name .. ":"
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.ZIndex = 10
        label.Parent = DetailsContent
        
        -- Value
        local valueLabel = Instance.new("TextLabel")
        valueLabel.Size = UDim2.new(0.7, -10, 0, 20)
        valueLabel.Position = UDim2.new(0.3, 5, 0, (i-1) * 25 + 5)
        valueLabel.BackgroundTransparency = 1
        valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        valueLabel.Font = Enum.Font.SourceSans
        valueLabel.TextSize = 14
        valueLabel.Text = detail.value
        valueLabel.TextXAlignment = Enum.TextXAlignment.Left
        valueLabel.TextWrapped = true
        valueLabel.ZIndex = 10
        valueLabel.Parent = DetailsContent
    end
    
    -- Update canvas size
    DetailsContent.CanvasSize = UDim2.new(0, 0, 0, #details * 25 + 10)
    
    -- Show the panel
    DetailsPanel.Visible = true
end

-- Update displayed values in real-time
local function updateDisplayedValues()
    for _, child in pairs(ResultsList:GetChildren()) do
        if child:IsA("Frame") then
            local index = tonumber(string.match(child.Name, "Row_(%d+)"))
            if index and currentResults[index] then
                local resultData = currentResults[index]
                
                -- Skip locked values
                if lockedValues[resultData.path] then continue end
                
                -- Update current value if possible
                pcall(function()
                    local newValue = nil
                    
                    if resultData.valueGetter then
                        newValue = resultData.valueGetter()
                    elseif resultData.object and resultData.key then
                        newValue = resultData.object[resultData.key]
                    end
                    
                    if newValue ~= nil and newValue ~= resultData.value then
                        -- Update the stored value
                        resultData.value = newValue
                        
                        -- Update the display
                        for _, child in pairs(child:GetChildren()) do
                            if child:IsA("TextBox") then
                                child.Text = formatValue(newValue)
                                -- Flash to show changed value
                                child.BackgroundColor3 = Color3.fromRGB(70, 130, 180)
                                delay(0.3, function()
                                    child.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
                                end)
                            end
                        end
                    end
                end)
            end
        end
    end
end

-- Start real-time updates
local function startRealTimeUpdates()
    if realTimeEnabled and #currentResults > 0 and not updateTimer then
        updateTimer = RunService.Heartbeat:Connect(function()
            updateDisplayedValues()
        end)
    end
end

