-- Helper to parse the special lines from code
local function parseDecompileOutput(fullText: string)
	-- We look for consecutive lines starting with `-- Decompiler ...`, up to some pattern,
	-- or just lines that mention Konstant, etc. You can tailor as needed.
	local outputLines = {}
	local restLines = {}
	local foundSpecialBlock = false

	for line in fullText:gmatch("[^\n]*\n?") do
		if line:match("^%-%-%s*Decompiler will be improved soon!") or
			line:match("^%-%- Decompiled with") or
			line:match("^%-%- Decompiled on") or
			line:match("^%-%- Luau version") or
			line:match("^%-%- Time taken:") then

			foundSpecialBlock = true
			table.insert(outputLines, line)
		else
			-- If it's not the recognized "output lines," just assume it's code
			table.insert(restLines, line)
		end
	end

	return table.concat(outputLines), table.concat(restLines)
end

-------------------------------------------------------------------
-- Populate Scripts and Handle Button Clicks
local scriptData: { [string]: string } = {}

local function decompileScripts()
	local scripts = game.StarterPlayer.StarterPlayerScripts:GetChildren()
	local yPos = 5
	for _, scr in ipairs(scripts) do
		if scr:IsA("LocalScript") then
			local success, scriptContents = pcall(function()
				return decompile(scr)
			end)
			if success and scriptContents then
				scriptData[scr.Name] = scriptContents
			else
				scriptData[scr.Name] = "-- Failed to decompile script: " .. scr.Name
			end

			local button = Instance.new("TextButton")
			button.Name = scr.Name .. "Button"
			button.Text = scr.Name
			button.TextColor3 = Color3.new(1, 1, 1)
			button.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
			button.BorderSizePixel = 0
			button.Position = UDim2.new(0, 5, 0, yPos)
			button.Size = UDim2.new(1, -10, 0, 30)
			button.Font = Enum.Font.SourceSans
			button.TextSize = 16
			button.Parent = ScriptListFrame

			button.MouseButton1Click:Connect(function()
				local fullText = scriptData[scr.Name] or "No content available."
				local outputSection, codeSection = parseDecompileOutput(fullText)

				OutputLabel.Text = outputSection ~= "" and outputSection or ""
				CodeTextBox.Text = codeSection ~= "" and codeSection or "-- No code."
				
				-- Reset size & scroll positions
				local tb = CodeTextBox.TextBounds
				CodeTextBox.Size = UDim2.new(0, math.max(tb.X + 10, CodeViewFrame.AbsoluteSize.X - 10), 0, tb.Y + 10)
				CodeViewFrame.CanvasSize = UDim2.new(0, CodeTextBox.AbsoluteSize.X, 0, CodeTextBox.AbsoluteSize.Y + 10)
				CodeViewFrame.CanvasPosition = Vector2.new()
				HScrollBar.Position = UDim2.new(0, 0, 0, 0)
			end)

			yPos = yPos + 35
		end
	end

	ScriptListFrame.CanvasSize = UDim2.new(0, 0, 0, yPos)
end

decompileScripts()
