printl("ESP STARTING")
local esps = {}
local count = 0

for _, m in pairs(workspace:GetDescendants()) do
    if m:IsA("Model") then
        local hrp = m:FindFirstChild("HumanoidRootPart")
        if hrp then
            count = count + 1
            local txt = Drawing.new("Text")
            txt.Text = m.Name
            txt.Color = Color3(1, 1, 0)
            txt.Visible = true
            table.insert(esps, {m=m, r=hrp, t=txt})
        end
    end
end

printl("Found " .. count .. " models")

while true do
    for _, e in pairs(esps) do
        if e.m and e.r then
            pcall(function()
                local p, o = WorldToScreen(e.r.Position + Vector3(0, 3, 0))
                if p and o then
                    e.t.Position = p
                    e.t.Visible = true
                else
                    e.t.Visible = false
                end
            end)
        else
            e.t.Visible = false
        end
    end
    wait(0.01)
end
